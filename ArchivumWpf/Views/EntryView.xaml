<UserControl x:Class="ArchivumWpf.Views.EntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:models="clr-namespace:ArchivumWpf.Models"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Background" Value="#0A000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2" Margin="2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A107C41"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A107C41"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="CleanComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <fa:ImageAwesome Icon="ChevronDown" Width="10" Height="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="{DynamicResource CardBackground}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" CornerRadius="2" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="250">
                                    <ScrollViewer Margin="0,2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PART_Watermark" Text="{x:Static loc:Strings.Ent_DatePickerWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="13" VerticalAlignment="Center" Margin="2,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=DatePickerTextBox}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanDatePicker" TargetType="DatePicker">
            <Setter Property="CalendarStyle" Value="{StaticResource ModernCalendarStyle}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Margin="{TemplateBinding Padding}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" FontSize="13"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="30" Margin="0,0,5,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <fa:ImageAwesome Icon="Calendar" Width="12" Height="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        
        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Background" Value="#0A000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>s

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Ent_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="18" FontWeight="SemiBold" Margin="0,0,15,0"/>
                    <Rectangle Width="1" Height="14" Fill="{DynamicResource BorderColor}" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Grid.RowSpan="2" Background="Transparent" BorderThickness="0" Margin="0,15,0,0">
            <TabControl.Resources>
                
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TabPanel x:Name="HeaderPanel" Grid.Row="0" IsItemsHost="true" Margin="15,0,15,0" Panel.ZIndex="1"/>
                                    
                                    <Border Grid.Row="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                                        <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" 
                                        Padding="15,8" 
                                        Margin="2,0,2,-1" 
                                        BorderThickness="1,1,1,0" 
                                        BorderBrush="Transparent" 
                                        Background="Transparent" 
                                        CornerRadius="4,4,0,0" 
                                        Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource CardBackground}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{x:Static loc:Strings.Ent_TabAdd}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15,20,15,15">
                    <StackPanel HorizontalAlignment="Stretch" MaxWidth="1000">
                        
                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2" Padding="25">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.Ent_PrimaryClass}" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblRrNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddRrNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblSector}" Style="{StaticResource FormLabel}"/>
                                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding AddSector, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanComboBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblSubjectName}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddFileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblSecondaryIdOptional}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddSubjectNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblFileType}" Style="{StaticResource FormLabel}"/>
                                        <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding AddFileType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanComboBox}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{DynamicResource BorderColor}" Margin="0,10,0,25"/>

                                <TextBlock Text="{x:Static loc:Strings.Ent_ChronoPhysicalData}" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblStartDate}" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding AddStartDate}" Style="{StaticResource CleanDatePicker}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblEndDate}" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding AddEndDate}" Style="{StaticResource CleanDatePicker}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblTotalPages}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddTotalPages, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblShelfNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddShelfNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblDeckNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddDeckNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="4">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblFileNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding AddFileNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Command="{Binding ClearAddFormCommand}" Content="{x:Static loc:Strings.Ent_BtnClearForm}" Background="Transparent" Foreground="{DynamicResource TextMuted}" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Padding="15,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Button Command="{Binding SaveNewFileCommand}" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource CardBackground}" BorderThickness="0" Cursor="Hand" Padding="25,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                <fa:ImageAwesome Icon="Save" Width="12" Height="12" Margin="0,0,8,0" Foreground="{DynamicResource CardBackground}"/>
                                                <TextBlock Text="{x:Static loc:Strings.Ent_BtnSaveRecord}" FontWeight="SemiBold" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Ent_TabAmend}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15,20,15,15">
                    <StackPanel HorizontalAlignment="Stretch" MaxWidth="1000">
                        
                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2" Padding="15,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <fa:ImageAwesome Grid.Column="0" Icon="Edit" Width="14" Height="14" Foreground="{DynamicResource TextMuted}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                
                                <TextBox Grid.Column="1" Text="{Binding SearchRrNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                         FontSize="14" VerticalContentAlignment="Center" Margin="0,0,15,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="{x:Static loc:Strings.Ent_AmendSearchWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="14"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" Command="{Binding SearchFileToEditCommand}" 
                                        Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource CardBackground}" BorderThickness="0" Padding="20,6" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Search" Width="12" Height="12" Foreground="{TemplateBinding Foreground}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Ent_BtnLocateRecord}" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2" Padding="25" IsEnabled="{Binding IsEditFormEnabled}">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.Ent_PrimaryClass}" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblRrNumberLockEdit}" Style="{StaticResource FormLabel}" Foreground="{DynamicResource DangerAccent}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBox Grid.Column="0" Text="{Binding EditRrNumber, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource CleanTextBox}" 
                                                     IsReadOnly="{Binding IsChecked, ElementName=RrLockToggle}"/>
                                             
                                            <ToggleButton x:Name="RrLockToggle" Grid.Column="1" IsChecked="True" Margin="10,0,0,0" Width="32" Height="32" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Cursor="Hand" ToolTip="{x:Static loc:Strings.Ent_TooltipUnlockEdit}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                                                            <fa:ImageAwesome x:Name="LockIcon" Icon="Lock" Width="12" Height="12" Foreground="{DynamicResource DangerAccent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter TargetName="LockIcon" Property="Icon" Value="Unlock"/>
                                                                <Setter TargetName="LockIcon" Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblSector}" Style="{StaticResource FormLabel}"/>
                                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding EditSector, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanComboBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblFileType}" Style="{StaticResource FormLabel}"/>
                                        <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding EditFileType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanComboBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblSubjectName}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EditFileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{DynamicResource BorderColor}" Margin="0,10,0,25"/>

                                <TextBlock Text="{x:Static loc:Strings.Ent_ChronoPhysicalData}" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblSecondaryId}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EditSubjectNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblTotalPages}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EditTotalPages, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblStartDate}" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding EditStartDate}" Style="{StaticResource CleanDatePicker}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblEndDate}" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding EditEndDate}" Style="{StaticResource CleanDatePicker}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblShelfNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EditShelfNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblDeckNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EditDeckNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="4">
                                        <TextBlock Text="{x:Static loc:Strings.Ent_LblFileNumber}" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EditFileNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}"/>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Command="{Binding ClearEditFormCommand}" Content="{x:Static loc:Strings.Ent_BtnCancelAmendment}" Background="Transparent" Foreground="{DynamicResource DangerAccent}" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Padding="15,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Button Command="{Binding UpdateFileCommand}" IsEnabled="{Binding IsEditFormEnabled}" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource CardBackground}" BorderThickness="0" Cursor="Hand" Padding="25,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                <fa:ImageAwesome Icon="Save" Width="12" Height="12" Margin="0,0,8,0" Foreground="{DynamicResource CardBackground}"/>
                                                <TextBlock Text="{x:Static loc:Strings.Ent_BtnCommitChanges}" FontWeight="SemiBold" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Ent_TabAudit}">
                <DataGrid ItemsSource="{Binding HistoryRecords}" 
                          SelectedItem="{Binding SelectedHistoryRecord, Mode=TwoWay}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextMain}" 
                          RowBackground="{DynamicResource CardBackground}" AlternatingRowBackground="{DynamicResource WindowBackground}" 
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}" 
                          BorderThickness="0" Margin="15,10,15,15" MinHeight="400">
                    
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding ShowHistoryDetailsCommand}" />
                    </DataGrid.InputBindings>
                    
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Padding" Value="0,4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0A107C41"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1A107C41"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColTimestamp}" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColAction}" Binding="{Binding ActionType}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActionType}" Value="Created">
                                            <Setter Property="Foreground" Value="{DynamicResource AvailableColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActionType}" Value="Edited">
                                            <Setter Property="Foreground" Value="{DynamicResource BorrowedColor}"/> 
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColRrNumber}" Binding="{Binding RrNumber}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Ent_ColSubjectName}" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileName}" Foreground="{DynamicResource TextMain}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SubjectNumber, TargetNullValue='-'}" Foreground="{DynamicResource TextMuted}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Ent_ColSector}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Sector}" ToolTip="{Binding Sector}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColStatus}" Binding="{Binding Status}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="0" Grid.RowSpan="3" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="#66000000"/>
            
            <Border Background="{DynamicResource CardBackground}" CornerRadius="2" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="750" MinWidth="500" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <fa:ImageAwesome Icon="History" Width="16" Height="16" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DialogTitle}" Foreground="{DynamicResource TextMain}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding RecordChanges}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="{DynamicResource CardBackground}" RowBackground="{DynamicResource CardBackground}" AlternatingRowBackground="{DynamicResource WindowBackground}" 
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MaxHeight="300">
                            
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Padding" Value="0,6"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColModifiedField}" Binding="{Binding FieldName}" Width="170">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColPriorValue}" Binding="{Binding OldValue}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerAccent}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="{x:Static loc:Strings.Ent_ColAmendedValue}" Binding="{Binding NewValue}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,20,0,0">
                            <Button Command="{Binding CloseDialogCommand}" Content="{x:Static loc:Strings.Ent_BtnDismissLog}" 
                                    Height="32" Width="150" HorizontalAlignment="Right" Background="{DynamicResource BorderColor}" 
                                    Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
    </Grid>
</UserControl>