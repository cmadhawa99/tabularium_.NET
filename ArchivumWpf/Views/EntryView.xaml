<UserControl x:Class="ArchivumWpf.Views.EntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid>
        
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ENTRY MANAGEMENT" Foreground="#d4af37" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#252525"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="Margin" Value="0,0,5,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#d4af37"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Add New Entry">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Background="#1E1E1E" CornerRadius="0,8,8,8" Padding="30" MaxWidth="900">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="30"/> <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="RR Number *" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding AddRrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="Sector *" Foreground="Gray" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding AddSector, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                                        <TextBlock Text="File Name *" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding AddFileName, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="Subject Number" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding AddSubjectNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="File Type" Foreground="Gray" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding AddFileType, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,5"/>
                                        <DatePicker SelectedDate="{Binding AddStartDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,5"/>
                                        <DatePicker SelectedDate="{Binding AddEndDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="Total Pages" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding AddTotalPages, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Text="PHYSICAL LOCATION" Foreground="#8f9bb3" FontWeight="Bold" Margin="0,15,0,10"/>
                                    <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="15"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="15"/> <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                            <TextBlock Text="Shelf Number" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding AddShelfNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                            <TextBlock Text="Deck Number" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding AddDeckNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Margin="0,0,0,15">
                                            <TextBlock Text="File Number" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding AddFileNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                    <Button Command="{Binding ClearAddFormCommand}" Content="Clear Form" Width="120" Height="40" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,15,0"/>
                                    <Button Command="{Binding SaveNewFileCommand}" Width="150" Height="40" Background="#d4af37" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:ImageAwesome Icon="Save" Width="14" Height="14" Margin="0,0,8,0" Foreground="Black"/>
                                            <TextBlock Text="Save to Vault"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Edit Entry">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Background="#1E1E1E" CornerRadius="0,8,8,8" Padding="30" MaxWidth="900">
                            <StackPanel>
                                <Border Background="#252525" Padding="15" CornerRadius="8" Margin="0,0,0,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <TextBlock Text="Search by RR Number to Edit" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding SearchRrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding SearchFileToEditCommand}" Content="Search" Width="100" Height="35" VerticalAlignment="Bottom" Background="#333333" Foreground="White" BorderThickness="0"/>
                                    </Grid>
                                </Border>

                                <Grid IsEnabled="{Binding IsEditFormEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="30"/> <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> 
                                        <RowDefinition Height="Auto"/> 
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/> 
                                        <RowDefinition Height="Auto"/> 
                                        <RowDefinition Height="Auto"/> 
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                                        <TextBlock Text="RR Number *" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding EditRrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="Sector *" Foreground="Gray" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding EditSector, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="File Type" Foreground="Gray" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding EditFileType, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                                        <TextBlock Text="File Name *" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding EditFileName, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="Subject Number" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding EditSubjectNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="Total Pages" Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding EditTotalPages, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,5"/>
                                        <DatePicker SelectedDate="{Binding EditStartDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,5"/>
                                        <DatePicker SelectedDate="{Binding EditEndDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Text="PHYSICAL LOCATION" Foreground="#8f9bb3" FontWeight="Bold" Margin="0,15,0,10"/>
                                    <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="15"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="15"/> <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                            <TextBlock Text="Shelf Number" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding EditShelfNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                            <TextBlock Text="Deck Number" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding EditDeckNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Margin="0,0,0,15">
                                            <TextBlock Text="File Number" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding EditFileNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                    <Button Command="{Binding ClearEditFormCommand}" Content="Cancel Edit" Width="120" Height="40" Background="Transparent" Foreground="#E57373" BorderThickness="0" Margin="0,0,15,0"/>
                                    <Button Command="{Binding UpdateFileCommand}" IsEnabled="{Binding IsEditFormEnabled}" Width="150" Height="40" Background="#4FC3F7" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:ImageAwesome Icon="Save" Width="14" Height="14" Margin="0,0,8,0" Foreground="Black"/>
                                            <TextBlock Text="Save Changes"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Audit History Log">
                    <Border Background="#1E1E1E" CornerRadius="0,8,8,8" Padding="15">
                        
                        <DataGrid ItemsSource="{Binding HistoryRecords}" 
                                  SelectedItem="{Binding SelectedHistoryRecord, Mode=TwoWay}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="White" RowBackground="#252525" AlternatingRowBackground="#1E1E1E" 
                                  HeadersVisibility="Column" GridLinesVisibility="None" 
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            
                            <DataGrid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding ShowHistoryDetailsCommand}" />
                            </DataGrid.InputBindings>
                            
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" />
                                
                                <DataGridTextColumn Header="Action" Binding="{Binding ActionType}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActionType}" Value="Created">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionType}" Value="Edited">
                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="RR Num" Binding="{Binding RrNumber}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Subject Num" Binding="{Binding SubjectNumber}"/>
                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}"/>
                                <DataGridTextColumn Header="Sector" Binding="{Binding Sector}"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>

        <Grid Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}}" Background="#99000000" Panel.ZIndex="100">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" BorderBrush="#333333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle}" Foreground="#d4af37" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <DataGrid ItemsSource="{Binding RecordChanges}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Background="Transparent" Foreground="White" RowBackground="#252525" AlternatingRowBackground="#1E1E1E" 
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333333">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Changed Field" Binding="{Binding FieldName}" FontWeight="Bold" Foreground="#d4af37" Width="*"/>
                            <DataGridTextColumn Header="Old Value" Binding="{Binding OldValue}" Foreground="#E57373" Width="*"/>
                            <DataGridTextColumn Header="New Value" Binding="{Binding NewValue}" Foreground="#4CAF50" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Command="{Binding CloseDialogCommand}" Content="Close Details" Height="40" Margin="0,20,0,0" Background="#333333" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
        
    </Grid>
</UserControl>