<Window x:Class="ArchivumWpf.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:converters="clr-namespace:ArchivumWpf.Converters"
        Title="Archivum Security Recovery" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <fa:ImageAwesome Icon="Shield" Width="20" Height="20" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,10,0"/>
                <TextBlock Text="System Recovery" Foreground="{DynamicResource PrimaryAccent}" FontSize="20" FontWeight="Bold"/>
            </StackPanel>
            
            <TextBlock Text="The security vault is missing. Please provide your database credentials and Master Recovery Key to restore access." TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>
            
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" FontWeight="SemiBold" Margin="0,0,0,15" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="20">
                <StackPanel>
                    
                    <TextBlock Text="Database Configuration" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="10"/> <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Host" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbHost}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Database Name" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbName}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="10"/> <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Username" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbUser}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Password" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbPassword}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderColor}" Margin="0,0,0,20"/>

                    <TextBlock Text="Master Recovery Key" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding RecoveryKeyInput, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="8" Margin="0,0,0,20" FontFamily="Consolas" BorderBrush="{DynamicResource BorderColor}"/>
                    
                    <Button Content="Verify and Restore" Command="{Binding RestoreSystemCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource PrimaryAccent}" Foreground="White" Padding="15,10" Cursor="Hand" IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>