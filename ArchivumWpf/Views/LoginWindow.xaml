<Window x:Class="ArchivumWpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Archivum Login" Width="450" MinHeight="550"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        xmlns:converters="clr-namespace:ArchivumWpf.Converters"
        Background="{DynamicResource WindowBackground}"
        TextElement.FontFamily="Segoe UI Variable, Segoe UI, sans-serif">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <!-- Win 11 Heavy Shadow for the Main Login Card -->
        <DropShadowEffect x:Key="Win11ShadowHeavy" BlurRadius="32" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.20"/>

        <!-- Fluent Styles -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CleanPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                     <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Animated Ambient Glow Effect Triggers -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="GlowOrb1" Storyboard.TargetProperty="Opacity" From="0.05" To="0.25" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="GlowOrb2" Storyboard.TargetProperty="Opacity" From="0.25" To="0.05" Duration="0:0:5" AutoReverse="True" RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <!-- The Shining Ambient Background -->
        <Grid ClipToBounds="True" IsHitTestVisible="False">
            <Ellipse x:Name="GlowOrb1" Width="350" Height="350" Fill="{DynamicResource PrimaryAccent}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <Ellipse x:Name="GlowOrb2" Width="300" Height="300" Fill="{DynamicResource AvailableColor}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-80">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Main Content -->
        <Grid Margin="32">
            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="40" Effect="{StaticResource Win11ShadowHeavy}" VerticalAlignment="Center">
                <Grid>
                    <!-- Standard Login View -->
                    <StackPanel Visibility="{Binding IsRecoveryMode, Converter={StaticResource InverseBoolToVis}}">
                        
                        <fa:ImageAwesome Icon="UserCircleOutline" Width="48" Height="48" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                        <TextBlock Text="System Login" Foreground="{DynamicResource TextMain}" FontSize="24" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Welcome back. Please authenticate." Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,32" HorizontalAlignment="Center"/>
                        
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerAccent}" FontSize="13" Margin="0,0,0,20" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="Username" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding UsernameInput}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Password" Style="{StaticResource FormLabel}"/>
                        <PasswordBox x:Name="LoginPasswordBox" PasswordChanged="LoginPasswordBox_PasswordChanged" Style="{StaticResource CleanPasswordBox}" Margin="0,0,0,32"/>

                        <Button Command="{Binding LoginCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource WindowBackground}" BorderThickness="0" Cursor="Hand" Padding="0,14" Margin="0,0,0,24">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                            <fa:ImageAwesome Icon="SignIn" Width="14" Height="14" Margin="0,0,10,0" Foreground="{DynamicResource WindowBackground}"/>
                                            <TextBlock Text="Authenticate" FontSize="15"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Command="{Binding ToggleRecoveryModeCommand}" Background="Transparent" Foreground="{DynamicResource PrimaryAccent}" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" Padding="10,5">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <TextBlock Text="Forgot Password?" FontSize="13" TextDecorations="Underline"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Recovery Mode View -->
                    <StackPanel Visibility="{Binding IsRecoveryMode, Converter={StaticResource BoolToVis}}">
                        
                        <fa:ImageAwesome Icon="Shield" Width="48" Height="48" Foreground="{DynamicResource DangerAccent}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                        <TextBlock Text="Account Recovery" Foreground="{DynamicResource TextMain}" FontSize="24" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Provide your Master Key to reset." Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,32" HorizontalAlignment="Center"/>
                        
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerAccent}" FontSize="13" Margin="0,0,0,20" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="Master Recovery Key" Foreground="{DynamicResource DangerAccent}" FontSize="13" Margin="2,0,0,6"/>
                        <PasswordBox x:Name="MasterKeyBox" PasswordChanged="MasterKeyBox_PasswordChanged" Style="{StaticResource CleanPasswordBox}" FontFamily="Consolas" Margin="0,0,0,20"/>
                        
                        <Rectangle Height="1" Fill="{DynamicResource BorderColor}" Margin="0,4,0,24"/>
                        
                        <TextBlock Text="New Username" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding NewUsernameInput}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="New Password" Style="{StaticResource FormLabel}"/>
                        <PasswordBox x:Name="NewPasswordBox" PasswordChanged="NewPasswordBox_PasswordChanged" Style="{StaticResource CleanPasswordBox}" Margin="0,0,0,32"/>

                        <Button Command="{Binding ResetAccountCommand}" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" BorderThickness="0" Cursor="Hand" Padding="0,14" Margin="0,0,0,24">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                            <fa:ImageAwesome Icon="Refresh" Width="14" Height="14" Margin="0,0,10,0" Foreground="{DynamicResource WindowBackground}"/>
                                            <TextBlock Text="Verify and Reset" FontSize="15"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Command="{Binding ToggleRecoveryModeCommand}" Background="Transparent" Foreground="{DynamicResource TextMuted}" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" Padding="10,5">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <TextBlock Text="Return to Login" FontSize="13"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>