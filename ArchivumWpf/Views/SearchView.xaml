<UserControl x:Class="ArchivumWpf.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:models="clr-namespace:ArchivumWpf.Models"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="FilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Background" Value="#0A000000"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CleanComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1E1E"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#333333"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#f2ca50"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#f2ca50"/>
            </Style.Resources>
        </Style>

        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Background" Value="#0A000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Ellipse Width="900" Height="900" Fill="{DynamicResource PrimaryAccent}" Opacity="0.08" 
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-400,-200,0" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="250"/>
            </Ellipse.Effect>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,20,20">
            <StackPanel MaxWidth="1600" Margin="0,10,0,0">
                
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="28" Padding="6" Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <fa:ImageAwesome Grid.Column="0" Icon="Database" Width="18" Height="18" Foreground="{DynamicResource PrimaryAccent}" Margin="20,0,15,0"/>
                        
                        <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                 FontSize="16" FontFamily="Georgia" VerticalContentAlignment="Center" Margin="0,0,20,0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Enter record identifier, subject, or curator name..." Foreground="{DynamicResource TextMuted}" Opacity="0.5" FontSize="16" FontFamily="Georgia"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        
                        <Button Grid.Column="2" Command="{Binding PerformSearchCommand}" 
                                Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource WindowBackground}" 
                                FontWeight="Bold" BorderThickness="0" Padding="35,14" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                            <fa:ImageAwesome Icon="Search" Width="14" Height="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,10,0"/>
                                            <TextBlock Text="Execute Search" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="FILTER BY DATE:" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,25,0"/>
                    
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="15,6" Margin="0,0,15,0" Background="{DynamicResource CardBackground}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="YEAR:" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}" Style="{StaticResource CleanComboBox}" Width="70"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="15,6" Background="{DynamicResource CardBackground}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MONTH:" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding SelectedMonth}" Style="{StaticResource CleanComboBox}" Width="90"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,40">
                    <TextBlock Text="QUICK FILTERS:" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,25,0"/>
                    
                    <Border BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1" CornerRadius="18" Padding="15,6" Margin="0,0,10,0" Background="#0A000000">
                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding SelectedSector}" Style="{StaticResource CleanComboBox}"/>
                    </Border>

                    <ToggleButton Content="Recent (24h)" IsChecked="{Binding IsRecentActive}" Style="{StaticResource FilterToggleStyle}"/>
                    <ToggleButton Content="Available Only" IsChecked="{Binding IsAvailableActive}" Style="{StaticResource FilterToggleStyle}"/>
                    <ToggleButton Content="Removed" IsChecked="{Binding IsRemovedActive}" Style="{StaticResource FilterToggleStyle}"/>
                </StackPanel>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Registry Ledger" Foreground="{DynamicResource TextMain}" FontSize="22" FontFamily="Georgia" FontWeight="Bold"/>
                        <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,4,0,0">
                            <Run Text="Showing "/>
                            <Run Text="{Binding TotalResultsCount, Mode=OneWay}"/>
                            <Run Text=" synchronized records"/>
                        </TextBlock>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15,8" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SORT BY:" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Date Added" Foreground="{DynamicResource PrimaryAccent}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="0,10">
                    <StackPanel>
                        <DataGrid ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedFile}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="{DynamicResource TextMain}" 
                                  RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                                  HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" MinHeight="350" Margin="10,0">
                            
                            <DataGrid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDetailsCommand}"/>
                            </DataGrid.InputBindings>
                            
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Padding" Value="20,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Padding" Value="0,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#05000000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="IDENTIFIER" Binding="{Binding RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontFamily="Consolas" Width="140"/>
                                
                                <DataGridTemplateColumn Header="SUBJECT NAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:FileRecord}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMain}" FontFamily="Georgia" FontSize="15" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SubjectNumber, TargetNullValue='No Secondary ID'}" Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="SECTOR" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:FileRecord}">
                                            <Border BorderBrush="{Binding SectorColorHex}" BorderThickness="1" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SectorColorHex}" Opacity="0.1"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Sector}" Foreground="{Binding SectorColorHex}" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="ORIGIN DATE" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:FileRecord}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AddedDateTime, StringFormat=MMM dd}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding AddedDateTime, StringFormat=yyyy}" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="STATUS" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:FileRecord}">
                                            <Border BorderThickness="1" CornerRadius="12" Padding="12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                                        <Setter Property="Background" Value="#1AFFE088"/> 
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentStatus}" Value="Removed">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource DangerAccent}"/>
                                                                <Setter Property="Background" Value="#1AFFB4AB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CurrentStatus}" Value="Borrowed">
                                                                <Setter Property="BorderBrush" Value="#E5C365"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="4" Height="4" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource PrimaryAccent}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Removed">
                                                                        <Setter Property="Fill" Value="{DynamicResource DangerAccent}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding CurrentStatus}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Removed">
                                                                        <Setter Property="Foreground" Value="{DynamicResource DangerAccent}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="ACTIONS" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:FileRecord}">
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Padding="10">
                                                <fa:ImageAwesome Icon="EllipsisV" Width="4" Height="14" Foreground="{DynamicResource TextMuted}"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="30,20" Background="{DynamicResource CardBackground}" CornerRadius="0,0,16,16">
                            <Grid>
                                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12">
                                    <Run Text="Showing matching results"/>
                                </TextBlock>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource PaginationButtonStyle}" Padding="12,8" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="ChevronLeft" Width="10" Height="10" Foreground="{DynamicResource TextMuted}"/>
                                    </Button>
                                    
                                    <Border Background="{DynamicResource PrimaryAccent}" CornerRadius="8" Padding="16,8" Margin="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center">
                                            <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                    
                                    <Button Command="{Binding NextPageCommand}" Style="{StaticResource PaginationButtonStyle}" Padding="12,8">
                                        <fa:ImageAwesome Icon="ChevronRight" Width="10" Height="10" Foreground="{DynamicResource TextMuted}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <Grid Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVisConverter}}" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" BorderBrush="{Binding PopupBorderColor}" BorderThickness="2">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                        <fa:ImageAwesome Icon="FileText" Width="24" Height="24" Foreground="{Binding PopupBorderColor}" Margin="0,0,15,0"/>
                        <TextBlock Text="IMPERIAL DOSSIER" Foreground="{Binding PopupBorderColor}" FontSize="20" FontFamily="Georgia" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                            <RowDefinition Height="Auto"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial Number:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedFile.SerialNumber}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RR Number:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFile.RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sector:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFile.Sector}" Foreground="{Binding PopupBorderColor}" FontWeight="Bold" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Subject / File Name:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFile.FileName}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,15"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Subject Number:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFile.SubjectNumber}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="File Type:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedFile.FileType}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Chronological Span:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedFile.StartDate, StringFormat=dd MMM yyyy}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                            <TextBlock Text=" to " Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Text="{Binding SelectedFile.EndDate, StringFormat=dd MMM yyyy}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Total Pages:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedFile.TotalPages}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Physical Location:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Shelf " Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Text="{Binding SelectedFile.ShelfNumber}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBlock Text="Deck " Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Text="{Binding SelectedFile.DeckNumber}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <Button Command="{Binding CloseDetailsCommand}" Content="Close Dossier" 
                            Height="45" Margin="0,30,0,0" Background="{DynamicResource BorderColor}" 
                            Foreground="{DynamicResource TextMain}" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>