<UserControl x:Class="ArchivumWpf.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:models="clr-namespace:ArchivumWpf.Models"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             Background="{DynamicResource WindowBackground}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="FilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
             </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1A107C41"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CleanComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <fa:ImageAwesome Icon="ChevronDown" Width="8" Height="8" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="8,4,24,4" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False">
                                <Border x:Name="DropDownBorder" Background="{DynamicResource CardBackground}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                         </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="15,10">
            <StackPanel>
                <TextBlock Text="{x:Static loc:Strings.Sea_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2" Width="350" Margin="0,0,20,0" Background="{DynamicResource WindowBackground}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsStrictRrSearch}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="{x:Static loc:Strings.Sea_TooltipToggleStrict}" Padding="10,0,5,0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <Grid VerticalAlignment="Center">
                                                <fa:ImageAwesome Icon="Search" Width="12" Height="12" Foreground="{DynamicResource TextMuted}">
                                                    <fa:ImageAwesome.Style>
                                                        <Style TargetType="fa:ImageAwesome">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStrictRrSearch}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </fa:ImageAwesome.Style>
                                                </fa:ImageAwesome>

                                                <Border Width="16" Height="16" CornerRadius="2" Background="{DynamicResource PrimaryAccent}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStrictRrSearch}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{x:Static loc:Strings.Sea_StrictToggleIndicator}" Foreground="{DynamicResource CardBackground}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" FontSize="13" VerticalContentAlignment="Center" Margin="2,6,8,6">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Opacity="0.7" FontSize="13">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{x:Static loc:Strings.Sea_SearchWatermark}"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsStrictRrSearch}" Value="True">
                                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Sea_StrictSearchWatermark}"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button Grid.Column="2" Command="{Binding PerformSearchCommand}" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource CardBackground}" BorderThickness="0" Padding="15,0" Cursor="Hand">
                                <fa:ImageAwesome Icon="ArrowRight" Width="10" Height="10" Foreground="{DynamicResource CardBackground}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.Sea_FilterByDate}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}" Style="{StaticResource CleanComboBox}" Width="80" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding SelectedMonth}" Style="{StaticResource CleanComboBox}" Width="100"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.Sea_QuickFilters}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding SelectedSector}" Style="{StaticResource CleanComboBox}" MinWidth="110" Margin="0,0,10,0"/>
                        <ToggleButton Content="{x:Static loc:Strings.Sea_FilterRecent}" IsChecked="{Binding IsRecentActive}" Style="{StaticResource FilterToggleStyle}"/>
                        <ToggleButton Content="{x:Static loc:Strings.Sea_FilterAvailable}" IsChecked="{Binding IsAvailableActive}" Style="{StaticResource FilterToggleStyle}"/>
                        <ToggleButton Content="{x:Static loc:Strings.Sea_FilterRemoved}" IsChecked="{Binding IsRemovedActive}" Style="{StaticResource FilterToggleStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedFile}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextMain}" 
                  RowBackground="{DynamicResource CardBackground}" AlternatingRowBackground="{DynamicResource WindowBackground}" 
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}" 
                  BorderThickness="0">
            
            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDetailsCommand}"/>
            </DataGrid.InputBindings>
            
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Padding" Value="0,4"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0A107C41"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1A107C41"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            
            <DataGrid.Columns>
                
                <DataGridTextColumn Header="{x:Static loc:Strings.Sea_ColIdentifier}" Binding="{Binding RrNumber}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
            
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0,0,0"/> </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTemplateColumn Header="{x:Static loc:Strings.Sea_ColSubjectName}" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:FileRecord}">
                            <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMain}" FontSize="13"/>
                                <TextBlock Text="{Binding SubjectNumber, TargetNullValue={x:Static loc:Strings.Sea_FallbackSecondaryId}}" Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="{x:Static loc:Strings.Sea_ColSector}" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:FileRecord}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Ellipse Width="8" Height="8" Fill="{Binding SectorColorHex}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Sector}" Foreground="{DynamicResource TextMain}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="{x:Static loc:Strings.Sea_ColOriginDate}" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:FileRecord}">
                            <TextBlock Text="{Binding AddedDateTime, StringFormat=dd MMM yyyy}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource TextMain}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="{x:Static loc:Strings.Sea_ColStatus}" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:FileRecord}">
                            <TextBlock Text="{Binding CurrentStatus}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                        <Style.Triggers>
                                            
                                            <DataTrigger Binding="{Binding CurrentStatus}" Value="Available">
                                                <Setter Property="Foreground" Value="{DynamicResource AvailableColor}"/>
                                            </DataTrigger>
                                            
                                            <DataTrigger Binding="{Binding CurrentStatus}" Value="Removed">
                                                <Setter Property="Foreground" Value="{DynamicResource RemovedColor}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentStatus}" Value="Borrowed">
                                                <Setter Property="Foreground" Value="{DynamicResource BorrowedColor}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="{DynamicResource PrimaryAccent}" Padding="15,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource CardBackground}" FontSize="11" Margin="0,0,15,0">
                        <Run Text="{x:Static loc:Strings.Sea_MainDesc_Part1}"/>
                        <Run Text="{Binding TotalResultsCount, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text="{x:Static loc:Strings.Sea_MainDesc_Part2}"/>
                    </TextBlock>
                    <Rectangle Width="1" Height="14" Fill="{DynamicResource CardBackground}" Opacity="0.3" Margin="0,0,15,0"/>
                    <TextBlock Text="{x:Static loc:Strings.Sea_ShowingMatchingResults}" Foreground="{DynamicResource CardBackground}" FontSize="11" Opacity="0.8"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding PreviousPageCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8,4" Margin="0,0,5,0">
                        <fa:ImageAwesome Icon="ChevronLeft" Width="8" Height="8" Foreground="{DynamicResource CardBackground}"/>
                    </Button>
                    <TextBlock Text="{Binding CurrentPage, Mode=OneWay}" Foreground="{DynamicResource CardBackground}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="5,0"/>
                    <Button Command="{Binding NextPageCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8,4" Margin="5,0,0,0">
                        <fa:ImageAwesome Icon="ChevronRight" Width="8" Height="8" Foreground="{DynamicResource CardBackground}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="0" Grid.RowSpan="3" Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="#66000000"/>
            
            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0" Width="400" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="20">
                        <Grid>
                            <TextBlock Text="{x:Static loc:Strings.Sea_FileRecords}" Foreground="{DynamicResource TextMain}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Ellipse Width="16" Height="16" Fill="{Binding SelectedFile.SectorColorHex}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="{Binding SelectedFile.Sector}"/>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:Strings.Sea_LblSerialNumber}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.SerialNumber}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblRrNumber}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontWeight="Bold" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblSector}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.Sector}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblSubjectFileName}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.FileName}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblSubjectNumber}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.SubjectNumber}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblFileType}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.FileType}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblChronoSpan}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15">
                                <Run Text="{Binding SelectedFile.StartDate, StringFormat=dd MMM yyyy}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding SelectedFile.EndDate, StringFormat=dd MMM yyyy}"/>
                            </TextBlock>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblTotalPages}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedFile.TotalPages}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15"/>

                            <TextBlock Text="{x:Static loc:Strings.Sea_LblPhysicalLocation}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13" Margin="0,2,0,15">
                                <Run Text="{x:Static loc:Strings.Sea_LblShelf}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding SelectedFile.ShelfNumber}"/>
                                <Run Text=" | "/>
                                <Run Text="{x:Static loc:Strings.Sea_LblDeck}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding SelectedFile.DeckNumber}"/>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="20" Background="{DynamicResource WindowBackground}">
                         <Button Command="{Binding CloseDetailsCommand}" Content="{x:Static loc:Strings.Sea_BtnCloseDossier}" 
                                Padding="0,10" Background="{DynamicResource BorderColor}" 
                                Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>