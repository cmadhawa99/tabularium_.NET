<UserControl x:Class="ArchivumWpf.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> <RowDefinition Height ="Auto"/>    </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                     Height="40" FontSize="16" Padding="10,0" VerticalContentAlignment="Center"
                     Background="#1E1E1E" Foreground="White" BorderBrush="#333333"/>
            
            <Button Grid.Column="1" Command="{Binding PerformSearchCommand}" 
                    Width="100" Height="40" Margin="10,0,0,0" 
                    Background="#d4af37" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                <StackPanel Orientation="Horizontal">
                    <fa:ImageAwesome Icon="Search" Width="14" Height="14" Margin="0,0,8,0" Foreground="Black"/>
                    <TextBlock Text="Search"/>
                </StackPanel>
            </Button>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding SearchResults}"
                  SelectedItem="{Binding SelectedFile}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="#1E1E1E" Foreground="White" RowBackground="#252525" 
                  AlternatingRowBackground="#1E1E1E" HeadersVisibility="Column" GridLinesVisibility="None">
            
            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDetailsCommand}"/>
            </DataGrid.InputBindings>
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="RR Number" Binding="{Binding RrNumber}" Width="150"/>
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                <DataGridTextColumn Header="Sector" Binding="{Binding Sector}" Width="150"/>
                <DataGridTextColumn Header="Status" Binding="{Binding CurrentStatus}" Width="100"/>
            </DataGrid.Columns>
            
        </DataGrid>
        
        <!-- Border Grid -->
        
        <Border Grid.Row="2" Background="#1E1E1E" Margin="0,10,0,0" Padding="10" CornerRadius="5">
            <Grid>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Gray" FontSize="14">
                    <Run Text="Total Records Found: "/>
                    <Run Text="{Binding TotalResultsCount, Mode=OneWay}" FontWeight="Bold" Foreground="White"/>
                </TextBlock>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    
                    <Button Command="{Binding PreviousPageCommand}" 
                            Content="&#x25C0; Previous" 
                            Width="90" Height="30" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,15,0"/>
                    
                    <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="14">
                        <Run Text="Page "/>
                        <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold" Foreground="#d4af37"/>
                        <Run Text=" of "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    
                    <Button Command="{Binding NextPageCommand}" 
                            Content="Next &#x25B6;" 
                            Width="90" Height="30" Background="#333333" Foreground="White" BorderThickness="0" Margin="15,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Stack Panel -->
        
        <Grid Grid.Row="0" Grid.RowSpan="3" 
              Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVisConverter}}" 
              Background="#99000000">
            
            <Border Background="#1E1E1E" CornerRadius="12" Padding="30" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" 
                    MinWidth="500" BorderBrush="#333333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="FILE DETAILS" Foreground="#d4af37" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial Number:" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedFile.SerialNumber}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RR Number:" Foreground="Gray"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFile.RrNumber}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sector:" Foreground="Gray"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFile.Sector}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Subject Number:" Foreground="Gray"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFile.SubjectNumber}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="File Name:" Foreground="Gray"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFile.FileName}" Foreground="White" FontWeight="Bold" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="File Type:" Foreground="Gray"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedFile.FileType}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Start Date:" Foreground="Gray"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedFile.StartDate, StringFormat=dd MMM yyyy}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="End Date:" Foreground="Gray"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedFile.EndDate, StringFormat=dd MMM yyyy}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Total Pages:" Foreground="Gray"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedFile.TotalPages}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Shelf Number:" Foreground="Gray"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedFile.ShelfNumber}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Deck Number:" Foreground="Gray"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SelectedFile.DeckNumber}" Foreground="White" FontWeight="Bold"/>

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="File Number:" Foreground="Gray"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding SelectedFile.FileNumber}" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <Button Command="{Binding CloseDetailsCommand}" Content="Close Details" 
                            Height="40" Margin="0,20,0,0" Background="#333333" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
        
    </Grid>
</UserControl>

