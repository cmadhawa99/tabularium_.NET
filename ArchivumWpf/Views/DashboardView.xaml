<UserControl x:Class="ArchivumWpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,30">
                
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="4,1,1,1" CornerRadius="8" Margin="0,0,20,0" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <fa:ImageAwesome Icon="Bank" Width="80" Height="80" Foreground="{DynamicResource PrimaryAccent}" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                        <StackPanel>
                            <TextBlock Text="TOTAL HOLDINGS" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding TotalHoldings}" Foreground="{DynamicResource PrimaryAccent}" FontSize="48" FontWeight="Light" FontFamily="Georgia"/>
                                <TextBlock Text="+12 this week (THIS IS A HARDCODED VALUE)" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="15,0,0,10" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="4,1,1,1" CornerRadius="8" Margin="10,0,10,0" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <fa:ImageAwesome Icon="Book" Width="80" Height="80" Foreground="{DynamicResource TextMuted}" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                        <StackPanel>
                            <TextBlock Text="ACTIVE LOANS" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding ActiveLoans}" Foreground="{DynamicResource TextMain}" FontSize="48" FontWeight="Light" FontFamily="Georgia"/>
                                <TextBlock Text="pending return" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="15,0,0,10" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="4,1,1,1" CornerRadius="8" Margin="20,0,0,0" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <fa:ImageAwesome Icon="Trash" Width="80" Height="80" Foreground="{DynamicResource DangerAccent}" Opacity="0.05" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                        <StackPanel>
                            <TextBlock Text="ARCHIVED / PURGED" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding ArchivedPurged}" Foreground="{DynamicResource TextMain}" Opacity="0.5" FontSize="48" FontWeight="Light" FontFamily="Georgia"/>
                                <TextBlock Text="All records intact" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="15,0,0,10" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Margin="0,0,15,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="25,20">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="History" Width="18" Height="18" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,15,0"/>
                                    <TextBlock Text="VAULT ACTIVITY CHRONICLE" Foreground="{DynamicResource PrimaryAccent}" FontSize="16" FontWeight="Bold" FontFamily="Georgia"/>
                                </StackPanel>
                                <Button Content="VIEW FULL LOG →" HorizontalAlignment="Right" Background="Transparent" Foreground="{DynamicResource TextMuted}" BorderThickness="0" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding RecentActivities}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="{DynamicResource TextMain}" RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                                  HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" Margin="10">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="15,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Padding" Value="0,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="REFERENCE ID" Binding="{Binding RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontFamily="Consolas"/>
                                <DataGridTextColumn Header="SUBJECT MATTER" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="ACTION TYPE" Binding="{Binding ActionType}"/>
                                <DataGridTextColumn Header="TIMESTAMP" Binding="{Binding Timestamp, StringFormat='MMM dd, HH:mm'}" Foreground="{DynamicResource TextMuted}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                    
                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="30" Margin="0,0,0,30">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="90" Height="90" CornerRadius="45" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="2" Margin="0,0,0,20">
                                <fa:ImageAwesome Icon="Gavel" Width="40" Height="40" Foreground="{DynamicResource PrimaryAccent}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Authority Confirmed" Foreground="{DynamicResource PrimaryAccent}" FontSize="20" FontWeight="Bold" FontFamily="Georgia" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Access to the Weligepola Imperial Vault is restricted to authorized Curators only." Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="250" Margin="0,0,0,20"/>
                            
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="STATUS" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Secured" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="LOAD" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Nominal" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="25">
                        <StackPanel>
                            <TextBlock Text="IMPERIAL MANDATES" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,20"/>
                            
                            <Button Background="Transparent" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="15" Margin="0,0,0,10" Cursor="Hand" HorizontalContentAlignment="Stretch">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <fa:ImageAwesome Icon="Book" Width="14" Height="14" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,15,0"/>
                                        <TextBlock Text="REQUEST RECORDS" Foreground="{DynamicResource PrimaryAccent}" FontSize="12" FontWeight="Bold"/>
                                    </StackPanel>
                                    <fa:ImageAwesome Icon="ChevronRight" Width="10" Height="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                            </Button>

                            <Button Background="Transparent" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="15" Cursor="Hand" HorizontalContentAlignment="Stretch">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <fa:ImageAwesome Icon="FileText" Width="14" Height="14" Foreground="{DynamicResource TextMain}" Margin="0,0,15,0"/>
                                        <TextBlock Text="CERTIFY LEDGER" Foreground="{DynamicResource TextMain}" FontSize="12" FontWeight="Bold"/>
                                    </StackPanel>
                                    <fa:ImageAwesome Icon="ChevronRight" Width="10" Height="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>