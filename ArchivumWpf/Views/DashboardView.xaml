<UserControl x:Class="ArchivumWpf.Views.DashboardView"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
            
            <Border Background="#1E1E1E" CornerRadius="10" Margin="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <fa:ImageAwesome Icon="Bank" Width="16" Height="16" Foreground="White" Margin="0,0,10,0"/>
                        <TextBlock Text="TOTAL HOLDINGS" Foreground="Gray" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalHoldings}" Foreground="White" FontSize="36" FontWeight="Light"/>
                </StackPanel>
            </Border>

            <Border Background="#1E1E1E" CornerRadius="10" Margin="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <fa:ImageAwesome Icon="LocationArrow" Width="16" Height="16" Foreground="#d4af37" Margin="0,0,10,0"/>
                        <TextBlock Text="ACTIVE LOANS" Foreground="#d4af37" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveLoans}" Foreground="#d4af37" FontSize="36" FontWeight="Light"/>
                </StackPanel>
                
            </Border>

            <Border Background="#1E1E1E" CornerRadius="10" Margin="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <fa:ImageAwesome Icon="Bug" Width="16" Height="16" Foreground="#E57373" Margin="0,0,10,0"/>
                        <TextBlock Text="ARCHIVED / PURGED" Foreground="#E57373" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ArchivedPurged}" Foreground="#E57373" FontSize="36" FontWeight="Light"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="10" Margin="10" Padding="20">
            <TextBlock Text="Vault Activity Log goes here..." Foreground="Gray" FontSize="16"/>
        </Border>

    </Grid>
</UserControl>