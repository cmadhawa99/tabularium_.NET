                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,0,15,16" FontSize="13"/>
