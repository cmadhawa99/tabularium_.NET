                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblReasonFormat}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,0,15,16" FontSize="13" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding PopupDisposalData.Reason}" Foreground="{DynamicResource TextMain}" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="14" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                            
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblAuthFormat}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,0,15,0" FontSize="13" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding PopupDisposalData.AuthorizedBy}" Foreground="{DynamicResource TextMain}" VerticalAlignment="Top" Margin="0,0,0,0" FontSize="14" TextWrapping="Wrap" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                        </Grid>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,24,0,0">
                            <Button Command="{Binding CloseDialogCommand}" Content="{x:Static loc:Strings.Dis_BtnCloseDossier}" 
                                    Height="40" MinWidth="160" HorizontalAlignment="Right" Background="{DynamicResource BorderColor}" 
                                    Foreground="{DynamicResource TextMain}" FontSize="14" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="3" Visibility="{Binding IsDisposalPromptOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="110">
            <Border Background="#66000000"/>
             
            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" MaxWidth="700" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="2" Effect="{StaticResource Win11ShadowHeavy}">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <fa:ImageAwesome Icon="Warning" Width="20" Height="20" Foreground="{DynamicResource DangerAccent}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AuthorizeDisposalTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="20"/>
                        </StackPanel>

                        <TextBlock FontSize="14" Margin="0,0,0,32" TextWrapping="Wrap">
                            <Run Text="{x:Static loc:Strings.Dis_LblTargetFileFormat}" Foreground="{DynamicResource TextMuted}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding PendingDisposalRrNumber}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                        </TextBlock>

                        <TextBlock Text="{x:Static loc:Strings.Dis_LblReasonForDisposal}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DisposalReason, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="{x:Static loc:Strings.Dis_LblAuthorizedBy}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding AuthorizedBy, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,32"/>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,24,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding CancelDisposalPromptCommand}" Content="{x:Static loc:Strings.Dis_BtnCancelRequest}" Background="Transparent" Foreground="{DynamicResource TextMuted}" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Padding="20,10">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                
                                <Button Command="{Binding ConfirmDisposalCommand}" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" BorderThickness="0" Cursor="Hand" Padding="24,10">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Trash" Width="14" Height="14" Margin="0,0,10,0" Foreground="{DynamicResource WindowBackground}"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Dis_BtnConfirmDestruction}" FontSize="14"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>