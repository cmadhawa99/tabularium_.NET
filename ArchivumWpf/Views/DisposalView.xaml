<UserControl x:Class="ArchivumWpf.Views.DisposalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             Background="{DynamicResource WindowBackground}"
             TextElement.FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <DropShadowEffect x:Key="Win11Shadow" BlurRadius="16" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.08"/>
        <DropShadowEffect x:Key="Win11ShadowHeavy" BlurRadius="24" ShadowDepth="6" Direction="270" Color="#000000" Opacity="0.15"/>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            
            <Style.Resources>
                <Style TargetType="CalendarItem">
                    <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                
                <Style TargetType="CalendarDayButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0A808080"/> 
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DangerAccent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource WindowBackground}"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="CalendarButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0A808080"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PART_Watermark" Text="Select a date..." Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="14" VerticalAlignment="Center" Margin="2,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=DatePickerTextBox}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanDatePicker" TargetType="DatePicker">
            <Setter Property="CalendarStyle" Value="{StaticResource ModernCalendarStyle}"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Margin="{TemplateBinding Padding}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" FontSize="14"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="30" Margin="0,0,5,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <fa:ImageAwesome Icon="Calendar" Width="12" Height="12" Foreground="{DynamicResource DangerAccent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Dis_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="20" Margin="0,0,20,0"/>
                    <Rectangle Width="1" Height="18" Fill="{DynamicResource BorderColor}" Margin="0,0,20,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Grid.RowSpan="2" Background="Transparent" BorderThickness="0" Margin="10,15,10,0" SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Resources>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TabPanel x:Name="HeaderPanel" Grid.Row="0" IsItemsHost="true" Margin="10,0,10,0" Panel.ZIndex="1"/>
                                    
                                    <Border Grid.Row="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                                        <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="24,12" Margin="2,0,2,-1" BorderThickness="1,1,1,0" Background="Transparent" BorderBrush="Transparent" CornerRadius="8,8,0,0" Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource CardBackground}"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{x:Static loc:Strings.Dis_TabSearch}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel HorizontalAlignment="Stretch" Margin="20,20,20,40" MaxWidth="1200">
                        
                        <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="24" Margin="0,0,0,25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <fa:ImageAwesome Grid.Column="0" Icon="Crosshairs" Width="16" Height="16" Foreground="{DynamicResource DangerAccent}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                
                                <TextBox Grid.Column="1" Text="{Binding SearchRrNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                         FontSize="15" VerticalContentAlignment="Center" Margin="0,0,20,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="{x:Static loc:Strings.Dis_SearchWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="15"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" Command="{Binding SearchFileCommand}" 
                                        Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource CardBackground}" 
                                        BorderThickness="0" Padding="24,10" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Search" Width="12" Height="12" Foreground="{TemplateBinding Foreground}" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Dis_BtnLocate}" FontSize="13"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <fa:ImageAwesome Icon="Archive" Width="56" Height="56" Foreground="{DynamicResource BorderColor}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AwaitingTargetTitle}" Foreground="{DynamicResource TextMuted}" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AwaitingTargetDesc}" Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center"/>
                        </StackPanel>

                        <Grid Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> 
                                <ColumnDefinition Width="30"/> 
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="32">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <Rectangle Width="4" Height="16" Fill="{Binding LoadedFileColor}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Static loc:Strings.Circ_DossierIntel}" Foreground="{DynamicResource TextMain}" FontSize="16"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblRrNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="13" Margin="0,0,15,16"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedFile.RrNumber}" Foreground="{DynamicResource PrimaryAccent}" VerticalAlignment="Center" FontSize="14" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSubjectName}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,0,15,16" FontSize="13"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LoadedFile.FileName}" Foreground="{DynamicResource TextMain}" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="14"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="13" Margin="0,0,15,16"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                                            <Ellipse Width="10" Height="10" Fill="{Binding LoadedFileColor}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding LoadedFile.Sector}" Foreground="{DynamicResource TextMain}" FontSize="14" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblCurrentStatus}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="13"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LoadedFile.CurrentStatus}" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center" FontSize="14"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Column="2">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LoadedFile.IsRemoved}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="2,0,0,0" Padding="24" CornerRadius="8" Margin="0,0,0,20">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Static loc:Strings.Dis_ScheduleTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="16" Margin="0,0,0,12"/>
                                            <TextBlock Text="{x:Static loc:Strings.Dis_ScheduleDesc}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,24" TextWrapping="Wrap"/>
                                            
                                            <TextBlock Text="{x:Static loc:Strings.Dis_LblToBeRemovedDate}" Style="{StaticResource FormLabel}"/>
                                            <DatePicker SelectedDate="{Binding ScheduledDate}" Style="{StaticResource CleanDatePicker}" Margin="0,0,0,20"/>
                                            
                                            <Button Command="{Binding UpdateQueueCommand}" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource CardBackground}" BorderThickness="0" Cursor="Hand" Padding="20,10" HorizontalAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <fa:ImageAwesome Icon="CalendarCheckOutline" Width="14" Height="14" Margin="0,0,10,0" Foreground="{DynamicResource CardBackground}"/>
                                                                <TextBlock Text="{x:Static loc:Strings.Dis_BtnUpdateQueue}" FontSize="13"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="2,0,0,0" Padding="24" CornerRadius="8">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Static loc:Strings.Dis_PermanentTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="16" Margin="0,0,0,12"/>
                                            <TextBlock Text="{x:Static loc:Strings.Dis_PermanentDesc}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,24" TextWrapping="Wrap"/>
                                            
                                            <Button Command="{Binding PromptDisposalCommand}" CommandParameter="" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" BorderThickness="0" Cursor="Hand" Padding="20,10" HorizontalAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <fa:ImageAwesome Icon="Warning" Width="14" Height="14" Margin="0,0,10,0" Foreground="{DynamicResource WindowBackground}"/>
                                                                <TextBlock Text="{x:Static loc:Strings.Dis_BtnExecuteDisposal}" FontSize="13"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border VerticalAlignment="Center" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="1" CornerRadius="8" Padding="32">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LoadedFile.IsRemoved}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <fa:ImageAwesome Icon="Ban" Width="42" Height="42" Foreground="{DynamicResource DangerAccent}" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_PermDisposedTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_PermDisposedDesc}" Foreground="{DynamicResource TextMuted}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Dis_TabQueue}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" MinWidth="350" MaxWidth="450" HorizontalAlignment="Left" Margin="20,20,20,10" Background="{DynamicResource WindowBackground}" Padding="8,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsStrictQueueSearch}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Toggle Strict RR Search" Padding="12,0,8,0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <Grid VerticalAlignment="Center">
                                                <fa:ImageAwesome Icon="Search" Width="14" Height="14" Foreground="{DynamicResource TextMuted}">
                                                    <fa:ImageAwesome.Style>
                                                        <Style TargetType="fa:ImageAwesome">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStrictQueueSearch}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </fa:ImageAwesome.Style>
                                                </fa:ImageAwesome>

                                                <Border Width="18" Height="18" CornerRadius="4" Background="{DynamicResource DangerAccent}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStrictQueueSearch}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="RR" Foreground="{DynamicResource CardBackground}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <TextBox Grid.Column="1" Text="{Binding QueueSearchQuery, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Margin="4,6,12,6">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Opacity="0.7" FontSize="14">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{x:Static loc:Strings.Sea_SearchWatermark}"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsStrictQueueSearch}" Value="True">
                                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Sea_StrictSearchWatermark}"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerAccent}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" Margin="20,10,20,10" ItemsSource="{Binding PendingRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Background="Transparent" Foreground="{DynamicResource TextMain}" 
                              RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                              HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" MinHeight="400">
                        
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenPendingDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                        </DataGrid.InputBindings>
                        
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
