                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsStrictHistorySearch}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Toggle Strict RR Search" Padding="12,0,8,0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <Grid VerticalAlignment="Center">
                                                <fa:ImageAwesome Icon="Search" Width="14" Height="14" Foreground="{DynamicResource TextMuted}">
