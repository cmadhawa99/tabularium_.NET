<UserControl x:Class="ArchivumWpf.Views.DisposalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCalendarStyle" TargetType="Calendar">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1E1E"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#e5e2e1"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#f2ca50"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#131313"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#252525"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#e5e2e1"/>
                <Style TargetType="CalendarDayButton">
                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                </Style>
                <Style TargetType="CalendarButton">
                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                </Style>
            </Style.Resources>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PART_Watermark" Text="Select a date..." Foreground="{DynamicResource TextMuted}" Opacity="0.5" VerticalAlignment="Center" Margin="4,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=DatePickerTextBox}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanDatePicker" TargetType="DatePicker">
            <Setter Property="CalendarStyle" Value="{StaticResource ModernCalendarStyle}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Margin="{TemplateBinding Padding}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" FontFamily="Georgia" FontSize="13"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="30" Margin="0,0,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <fa:ImageAwesome Icon="Calendar" Width="14" Height="14" Foreground="{DynamicResource PrimaryAccent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,0,0,6"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="0,10,20,20" MaxWidth="1600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{x:Static loc:Strings.Dis_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="32" FontFamily="Georgia" FontWeight="Black" Margin="0,0,0,5"/>
            <TextBlock Text="{x:Static loc:Strings.Dis_MainDesc}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,0,0,10"/>
            
            <Grid Margin="0,10,0,15">
                <Rectangle Height="1" Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>
                <Rectangle Width="8" Height="8" Fill="{DynamicResource BorderColor}" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center">
                    <Rectangle.RenderTransform>
                        <RotateTransform Angle="45"/>
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>
            
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="25,12" Margin="0,0,15,15" CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Background="{DynamicResource CardBackground}" Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#0A000000"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{x:Static loc:Strings.Dis_TabSearch}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,30,0,20">
                        
                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="32" Padding="8" Margin="0,0,0,40" Width="800" HorizontalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <fa:ImageAwesome Grid.Column="0" Icon="Crosshairs" Width="22" Height="22" Foreground="{DynamicResource DangerAccent}" Margin="25,0,20,0"/>
                                
                                <TextBox Grid.Column="1" Text="{Binding SearchRrNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                         FontSize="18" FontFamily="Georgia" VerticalContentAlignment="Center" Margin="0,0,10,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="{x:Static loc:Strings.Dis_SearchWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.5" FontSize="16" FontFamily="Georgia"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" Command="{Binding SearchFileCommand}" 
                                        Background="{DynamicResource BorderColor}" Foreground="{DynamicResource TextMain}" 
                                        FontWeight="Bold" BorderThickness="0" Padding="35,16" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="24">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Search" Width="14" Height="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Dis_BtnLocate}" FontSize="14"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            
                            <fa:ImageAwesome Icon="Archive" Width="120" Height="120" Foreground="{DynamicResource TextMuted}" Opacity="0.1" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AwaitingTargetTitle}" Foreground="{DynamicResource TextMuted}" Opacity="0.5" FontSize="18" FontWeight="Bold" FontFamily="Georgia" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AwaitingTargetDesc}" Foreground="{DynamicResource TextMuted}" Opacity="0.4" FontSize="14" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Grid Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}" MaxWidth="1000" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="30"/> <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="35" ClipToBounds="True">
                                <Grid>
                                    <fa:ImageAwesome Icon="ClockOutline" Width="120" Height="120" Foreground="{DynamicResource PrimaryAccent}" Opacity="0.05" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-25,-25,0" IsHitTestVisible="False"/>
                                    
                                    <StackPanel>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_ScheduleTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_ScheduleDesc}" Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,30"/>
                                        
                                        <TextBlock Text="{x:Static loc:Strings.Dis_LblToBeRemovedDate}" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="5,0,0,6"/>
                                        <DatePicker SelectedDate="{Binding ScheduledDate}" Style="{StaticResource CleanDatePicker}" Margin="0,0,0,30"/>
                                        
                                        <Button Command="{Binding UpdateQueueCommand}" Height="50" Background="{DynamicResource BorderColor}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Padding="30,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                            <fa:ImageAwesome Icon="CalendarCheckOutline" Width="16" Height="16" Margin="0,0,12,0" Foreground="{DynamicResource PrimaryAccent}"/>
                                                            <TextBlock Text="{x:Static loc:Strings.Dis_BtnUpdateQueue}" FontSize="13"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Background="#0A000000" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="1" CornerRadius="16" Padding="35" ClipToBounds="True">
                                <Grid>
                                    <fa:ImageAwesome Icon="Trash" Width="120" Height="120" Foreground="{DynamicResource DangerAccent}" Opacity="0.05" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-25,-25,0" IsHitTestVisible="False"/>

                                    <StackPanel>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_PermanentTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_PermanentDesc}" Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,30"/>
                                        
                                        <Button Command="{Binding PromptDisposalCommand}" CommandParameter="" Height="50" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" BorderThickness="0" Margin="0,65,0,0" Cursor="Hand" HorizontalAlignment="Left" Padding="30,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                            <fa:ImageAwesome Icon="Warning" Width="16" Height="16" Margin="0,0,12,0" Foreground="{DynamicResource WindowBackground}"/>
                                                            <TextBlock Text="{x:Static loc:Strings.Dis_BtnExecuteDisposal}" FontSize="13"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Dis_TabQueue}">
                <Border Background="{DynamicResource CardBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="3">
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="13">
                        <DataGrid ItemsSource="{Binding PendingRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="{DynamicResource TextMain}" RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                                  HeadersVisibility="Column" GridLinesVisibility="None" Margin="10,0">
                            
                            <DataGrid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenPendingDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                            </DataGrid.InputBindings>
                            
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Padding" Value="20,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Padding" Value="0,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#05000000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColScheduledFor}" Binding="{Binding ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Foreground="{DynamicResource DangerAccent}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColRrNumber}" Binding="{Binding RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontFamily="Consolas"/>
                                
                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColFileName}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColSector}" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Sector}" ToolTip="{Binding Sector}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColActions}" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.RecoverFileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding RrNumber}" Content="{x:Static loc:Strings.Dis_BtnRecover}" Background="{DynamicResource BorderColor}" Foreground="{DynamicResource TextMain}" BorderThickness="0" Height="28" Margin="0,0,8,0" Padding="15,0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding DataContext.PromptDisposalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding RrNumber}" Content="{x:Static loc:Strings.Dis_BtnDispose}" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" BorderThickness="0" Height="28" Padding="15,0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Border>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Dis_TabAudit}">
                <Border Background="{DynamicResource CardBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="3">
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="13">
                        <DataGrid ItemsSource="{Binding DisposedHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="{DynamicResource TextMain}" RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                                  HeadersVisibility="Column" GridLinesVisibility="None" Margin="10,0">
                            
                            <DataGrid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDisposedDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                            </DataGrid.InputBindings>
                            
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Padding" Value="20,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Padding" Value="0,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#05000000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColDateDisposed}" Binding="{Binding RemovedDate, StringFormat=yyyy-MM-dd}" Foreground="{DynamicResource TextMuted}"/>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColRrNumber}" Binding="{Binding File.RrNumber}" Foreground="{DynamicResource DangerAccent}" FontFamily="Consolas"/>
                                
                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColFileName}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding File.FileName}" ToolTip="{Binding File.FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColAuthorizedBy}" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AuthorizedBy}" ToolTip="{Binding AuthorizedBy}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColReason}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Reason}" ToolTip="{Binding Reason}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Border>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="0" Grid.RowSpan="2" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="#CC000000" CornerRadius="16"/>
            
            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" BorderBrush="{Binding PopupBorderColor, FallbackValue='#f2ca50'}" BorderThickness="2" ClipToBounds="True">
                <Grid>
                    <Grid Width="180" Height="180" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-30,-30,0" Opacity="0.15" IsHitTestVisible="False">
                        <fa:ImageAwesome Icon="FileText" Foreground="{DynamicResource TextMain}" Margin="-4,0,4,0"/>
                        <fa:ImageAwesome Icon="FileText" Foreground="{DynamicResource TextMain}" Margin="4,0,-4,0"/>
                        <fa:ImageAwesome Icon="FileText" Foreground="{DynamicResource TextMain}" Margin="0,-4,0,4"/>
                        <fa:ImageAwesome Icon="FileText" Foreground="{DynamicResource TextMain}" Margin="0,4,0,-4"/>
                        <fa:ImageAwesome Icon="FileText" Foreground="{Binding PopupBorderColor, FallbackValue='#f2ca50'}"/>
                    </Grid>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <fa:ImageAwesome Icon="FileText" Width="24" Height="24" Foreground="{Binding PopupBorderColor, FallbackValue='#f2ca50'}" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding PopupFileData.RrNumber}" Foreground="{Binding PopupBorderColor, FallbackValue='#f2ca50'}" FontSize="20" FontFamily="Georgia" FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Text="{Binding PopupFileData.FileName}" Foreground="{DynamicResource TextMain}" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,25"/>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/> <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PopupFileData.Sector}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblStatus}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PopupFileData.CurrentStatus}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblDisposalScheduled}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PopupFileData.ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Foreground="{DynamicResource DangerAccent}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="#0A000000" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="1" Padding="20" CornerRadius="12" Visibility="{Binding PopupDisposalData, Converter={StaticResource BoolToVisConverter}}">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.Dis_PermDisposedTitle}" Foreground="{DynamicResource DangerAccent}" FontWeight="Bold" Margin="0,0,0,10"/>
                                
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                                    <Run Text="{x:Static loc:Strings.Dis_LblReasonFormat}" Foreground="{DynamicResource TextMuted}"/>
                                    <Run Text="{Binding PopupDisposalData.Reason}" Foreground="{DynamicResource TextMain}"/>
                                </TextBlock>
                                
                                <TextBlock>
                                    <Run Text="{x:Static loc:Strings.Dis_LblAuthFormat}" Foreground="{DynamicResource TextMuted}"/>
                                    <Run Text="{Binding PopupDisposalData.AuthorizedBy}" Foreground="{DynamicResource TextMuted}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding CloseDialogCommand}" Content="{x:Static loc:Strings.Dis_BtnCloseDossier}" 
                                Height="45" Margin="0,30,0,0" Background="{DynamicResource BorderColor}" 
                                Foreground="{DynamicResource TextMain}" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="2" Visibility="{Binding IsDisposalPromptOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="110">
            <Border Background="#CC000000" CornerRadius="16"/>
            
            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="2" ClipToBounds="True">
                <Grid>
                    <fa:ImageAwesome Icon="Warning" Width="150" Height="150" Foreground="{DynamicResource DangerAccent}" Opacity="0.05" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0" IsHitTestVisible="False"/>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <fa:ImageAwesome Icon="Warning" Width="24" Height="24" Foreground="{DynamicResource DangerAccent}" Margin="0,0,15,0"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AuthorizeDisposalTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="20" FontFamily="Georgia" FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,25">
                            <Run Text="{x:Static loc:Strings.Dis_LblTargetFileFormat}" Foreground="{DynamicResource TextMuted}"/>
                            <Run Text="{Binding PendingDisposalRrNumber}" Foreground="{DynamicResource TextMain}"/>
                        </TextBlock>

                        <TextBlock Text="{x:Static loc:Strings.Dis_LblReasonForDisposal}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DisposalReason, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="{x:Static loc:Strings.Dis_LblAuthorizedBy}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding AuthorizedBy, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,35"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CancelDisposalPromptCommand}" Content="{x:Static loc:Strings.Dis_BtnCancelRequest}" Width="130" Height="45" Background="Transparent" Foreground="{DynamicResource TextMuted}" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand"/>
                            
                            <Button Command="{Binding ConfirmDisposalCommand}" Height="45" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="25,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                <fa:ImageAwesome Icon="Trash" Width="14" Height="14" Margin="0,0,10,0" Foreground="{DynamicResource WindowBackground}"/>
                                                <TextBlock Text="{x:Static loc:Strings.Dis_BtnConfirmDestruction}"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>