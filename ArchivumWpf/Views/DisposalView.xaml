<UserControl x:Class="ArchivumWpf.Views.DisposalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PART_Watermark" Text="Select a date..." Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="13" VerticalAlignment="Center" Margin="2,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=DatePickerTextBox}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanDatePicker" TargetType="DatePicker">
            <Setter Property="CalendarStyle" Value="{StaticResource ModernCalendarStyle}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Margin="{TemplateBinding Padding}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" FontSize="13"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="30" Margin="0,0,5,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <fa:ImageAwesome Icon="Calendar" Width="12" Height="12" Foreground="{DynamicResource DangerAccent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Dis_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="18" FontWeight="SemiBold" Margin="0,0,15,0"/>
                    <Rectangle Width="1" Height="14" Fill="{DynamicResource BorderColor}" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Grid.RowSpan="2" Background="Transparent" BorderThickness="0" Margin="0,15,0,0" SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="15,8" Margin="15,0,5,0" BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="Transparent" Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{x:Static loc:Strings.Dis_TabSearch}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15,20,15,15">
                    <StackPanel HorizontalAlignment="Stretch" MaxWidth="1000">
                        
                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2" Padding="15,10" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <fa:ImageAwesome Grid.Column="0" Icon="Crosshairs" Width="14" Height="14" Foreground="{DynamicResource DangerAccent}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                
                                <TextBox Grid.Column="1" Text="{Binding SearchRrNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                         FontSize="14" VerticalContentAlignment="Center" Margin="0,0,15,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="{x:Static loc:Strings.Dis_SearchWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="14"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" Command="{Binding SearchFileCommand}" 
                                        Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource CardBackground}" 
                                        BorderThickness="0" Padding="20,6" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Search" Width="12" Height="12" Foreground="{TemplateBinding Foreground}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Dis_BtnLocate}" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <fa:ImageAwesome Icon="Archive" Width="48" Height="48" Foreground="{DynamicResource BorderColor}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AwaitingTargetTitle}" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AwaitingTargetDesc}" Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Grid Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> 
                                <ColumnDefinition Width="20"/> 
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2" Padding="20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <Rectangle Width="4" Height="14" Fill="{Binding LoadedFileColor}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Static loc:Strings.Circ_DossierIntel}" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblRrNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedFile.RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSubjectName}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,8,0,0" FontSize="12"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LoadedFile.FileName}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,8,0,10" FontSize="13"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="{Binding LoadedFileColor}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding LoadedFile.Sector}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblCurrentStatus}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LoadedFile.CurrentStatus}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1,0,0,0" Padding="20,0,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Static loc:Strings.Dis_ScheduleTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_ScheduleDesc}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap"/>
                                        
                                        <TextBlock Text="{x:Static loc:Strings.Dis_LblToBeRemovedDate}" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding ScheduledDate}" Style="{StaticResource CleanDatePicker}" Margin="0,0,0,15"/>
                                        
                                        <Button Command="{Binding UpdateQueueCommand}" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource CardBackground}" BorderThickness="0" Cursor="Hand" Padding="15,8" HorizontalAlignment="Left">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                            <fa:ImageAwesome Icon="CalendarCheckOutline" Width="12" Height="12" Margin="0,0,8,0" Foreground="{DynamicResource CardBackground}"/>
                                                            <TextBlock Text="{x:Static loc:Strings.Dis_BtnUpdateQueue}" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="1,0,0,0" Padding="20,30,0,0" Margin="0,15,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Static loc:Strings.Dis_PermanentTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBlock Text="{x:Static loc:Strings.Dis_PermanentDesc}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap"/>
                                        
                                        <Button Command="{Binding PromptDisposalCommand}" CommandParameter="" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" BorderThickness="0" Cursor="Hand" Padding="15,8" HorizontalAlignment="Left">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                            <fa:ImageAwesome Icon="Warning" Width="12" Height="12" Margin="0,0,8,0" Foreground="{DynamicResource WindowBackground}"/>
                                                            <TextBlock Text="{x:Static loc:Strings.Dis_BtnExecuteDisposal}" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Dis_TabQueue}">
                <DataGrid ItemsSource="{Binding PendingRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextMain}" 
                          RowBackground="{DynamicResource CardBackground}" AlternatingRowBackground="{DynamicResource WindowBackground}" 
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}" 
                          BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="15,10,15,15" MinHeight="400">
                    
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenPendingDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                    </DataGrid.InputBindings>
                    
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Padding" Value="0,4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0A000000"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColScheduledFor}" Binding="{Binding ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerAccent}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColRrNumber}" Binding="{Binding RrNumber}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColFileName}" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColSector}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="{Binding SectorColorHex, TargetNullValue='#8f9bb3'}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Sector}" ToolTip="{Binding Sector}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColActions}" Width="320">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.RecoverFileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding RrNumber}" Content="{x:Static loc:Strings.Dis_BtnRecover}" Background="Transparent" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Foreground="{DynamicResource TextMain}" Height="28" Margin="0,0,8,0" Padding="12,0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Command="{Binding DataContext.PromptDisposalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding RrNumber}" Content="{x:Static loc:Strings.Dis_BtnDispose}" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" FontWeight="SemiBold" BorderThickness="0" Height="28" Padding="12,0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Dis_TabAudit}">
                <DataGrid ItemsSource="{Binding DisposedHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextMain}" 
                          RowBackground="{DynamicResource CardBackground}" AlternatingRowBackground="{DynamicResource WindowBackground}" 
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}" 
                          BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="15,10,15,15" MinHeight="400">
                            
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDisposedDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                    </DataGrid.InputBindings>
                        
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Padding" Value="0,4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0A000000"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColDateDisposed}" Binding="{Binding RemovedDate, StringFormat=yyyy-MM-dd}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Dis_ColRrNumber}" Binding="{Binding File.RrNumber}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerAccent}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColFileName}" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding File.FileName}" ToolTip="{Binding File.FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColAuthorizedBy}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AuthorizedBy}" ToolTip="{Binding AuthorizedBy}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Dis_ColReason}" Width="250">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Reason}" ToolTip="{Binding Reason}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="0" Grid.RowSpan="3" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="#66000000"/>
            
            <Border Background="{DynamicResource CardBackground}" CornerRadius="2" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Ellipse Width="16" Height="16" Fill="{Binding PopupBorderColor, TargetNullValue='#8f9bb3'}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top" ToolTip="{Binding PopupFileData.Sector}"/>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <fa:ImageAwesome Icon="FileText" Width="16" Height="16" Foreground="{DynamicResource TextMain}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DialogTitle}" Foreground="{DynamicResource TextMain}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/> 
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSubjectName}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" FontSize="12" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PopupFileData.FileName}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="12" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblRrNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PopupFileData.RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding PopupFileData.Sector}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.Sea_LblSubjectNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PopupFileData.SubjectNumber, TargetNullValue='N/A'}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10"/>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static loc:Strings.Sea_LblChronoSpan}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding PopupFileData.StartDate, StringFormat=dd MMM yyyy, TargetNullValue='N/A'}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text=" - " Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                    <TextBlock Text="{Binding PopupFileData.EndDate, StringFormat=dd MMM yyyy, TargetNullValue='N/A'}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>

                                <Rectangle Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Fill="{DynamicResource BorderColor}" VerticalAlignment="Center" Margin="0,10,0,20"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblStatus}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PopupFileData.CurrentStatus}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10"/>
                                
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblDisposalScheduled}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsPendingPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PopupFileData.ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Foreground="{DynamicResource DangerAccent}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsPendingPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="{x:Static loc:Strings.Dis_ColDateDisposed}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding PopupDisposalData.RemovedDate, StringFormat=yyyy-MM-dd}" Foreground="{DynamicResource DangerAccent}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                
                                <TextBlock Grid.Row="9" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblReasonFormat}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding PopupDisposalData.Reason}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                
                                <TextBlock Grid.Row="10" Grid.Column="0" Text="{x:Static loc:Strings.Dis_LblAuthFormat}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding PopupDisposalData.AuthorizedBy}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" Margin="0,0,0,10" Visibility="{Binding IsDisposedPopup, Converter={StaticResource BoolToVisConverter}}"/>
                            </Grid>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,20,0,0">
                            <Button Command="{Binding CloseDialogCommand}" Content="{x:Static loc:Strings.Dis_BtnCloseDossier}" 
                                    Height="32" Width="150" HorizontalAlignment="Right" Background="{DynamicResource BorderColor}" 
                                    Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="3" Visibility="{Binding IsDisposalPromptOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="110">
            <Border Background="#66000000"/>
            
            <Border Background="{DynamicResource CardBackground}" CornerRadius="2" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500" BorderBrush="{DynamicResource DangerAccent}" BorderThickness="2">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <fa:ImageAwesome Icon="Warning" Width="16" Height="16" Foreground="{DynamicResource DangerAccent}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.Dis_AuthorizeDisposalTitle}" Foreground="{DynamicResource DangerAccent}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,25">
                            <Run Text="{x:Static loc:Strings.Dis_LblTargetFileFormat}" Foreground="{DynamicResource TextMuted}"/>
                            <Run Text="{Binding PendingDisposalRrNumber}" Foreground="{DynamicResource TextMain}"/>
                        </TextBlock>

                        <TextBlock Text="{x:Static loc:Strings.Dis_LblReasonForDisposal}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DisposalReason, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="{x:Static loc:Strings.Dis_LblAuthorizedBy}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding AuthorizedBy, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,25"/>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding CancelDisposalPromptCommand}" Content="{x:Static loc:Strings.Dis_BtnCancelRequest}" Background="Transparent" Foreground="{DynamicResource TextMuted}" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Padding="15,8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                
                                <Button Command="{Binding ConfirmDisposalCommand}" Background="{DynamicResource DangerAccent}" Foreground="{DynamicResource WindowBackground}" BorderThickness="0" Cursor="Hand" Padding="25,8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Trash" Width="12" Height="12" Margin="0,0,8,0" Foreground="{DynamicResource WindowBackground}"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Dis_BtnConfirmDestruction}" FontWeight="SemiBold" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>