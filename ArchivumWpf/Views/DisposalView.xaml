                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static loc:Strings.Sea_LblChronoSpan}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,0,15,16" FontSize="13"/>
