<UserControl x:Class="ArchivumWpf.Views.DisposalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="RECORD DISPOSAL &amp; ARCHIVING" Foreground="#E57373" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                
                <Border Background="#1E1E1E" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Search File by RR Number" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SearchRrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding SearchFileCommand}" Content="Search Vault" Width="120" Height="35" VerticalAlignment="Bottom" Background="#333333" Foreground="White" BorderThickness="0"/>
                    </Grid>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="8" Padding="25" Margin="0,0,0,20" Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="FILE TARGET DETAILS" Foreground="Gray" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="RR Number" Foreground="#8f9bb3" FontSize="12"/>
                                <TextBlock Text="{Binding LoadedRrNumber}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Text="Current Status" Foreground="#8f9bb3" FontSize="12"/>
                                <TextBlock Text="{Binding LoadedStatus}" Foreground="#d4af37" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="File Name" Foreground="#8f9bb3" FontSize="12"/>
                                <TextBlock Text="{Binding LoadedFileName}" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Text="Sector" Foreground="#8f9bb3" FontSize="12"/>
                                <TextBlock Text="{Binding LoadedSector}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid IsEnabled="{Binding CanDispose}" Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="25">
                        <StackPanel>
                            <TextBlock Text="1. SCHEDULE DISPOSAL" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="Set a future date to automatically flag this file for removal in reports." Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="To-Be-Removed Date" Foreground="Gray" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding ScheduledDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,20"/>
                            
                            <Button Command="{Binding UpdateQueueCommand}" Height="40" Background="#333333" Foreground="White" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Calendar" Width="14" Height="14" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="Update Queue Status"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#2A1A1A" BorderBrush="#F44336" BorderThickness="1" CornerRadius="8" Padding="25">
                        <StackPanel>
                            <TextBlock Text="2. PERMANENT DISPOSAL" Foreground="#F44336" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="Instantly lock this record and log it in the disposal database." Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Reason for Disposal *" Foreground="#E57373" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding DisposalReason, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#1E1E1E" Foreground="White" BorderBrush="#F44336" Padding="5,0" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Authorized By *" Foreground="#E57373" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding AuthorizedBy, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#1E1E1E" Foreground="White" BorderBrush="#F44336" Padding="5,0" Margin="0,0,0,20"/>

                            <Button Command="{Binding ExecuteDisposalCommand}" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Trash" Width="14" Height="14" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="EXECUTE DISPOSAL"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>