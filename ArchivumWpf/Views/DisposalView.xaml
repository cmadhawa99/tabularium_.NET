<UserControl x:Class="ArchivumWpf.Views.DisposalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="RETENTION &amp; DISPOSAL" Foreground="#E57373" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#252525"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="Margin" Value="0,0,5,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#E57373"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Search &amp; Target">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="900" HorizontalAlignment="Left" Margin="0,20,0,0">
                            
                            <Border Background="#1E1E1E" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="Search File by RR Number" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SearchRrNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding SearchFileCommand}" Content="Search Vault" Width="120" Height="35" VerticalAlignment="Bottom" Background="#333333" Foreground="White" BorderThickness="0"/>
                                </Grid>
                            </Border>

                            <Grid Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/> <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="25">
                                    <StackPanel>
                                        <TextBlock Text="1. SCHEDULE DISPOSAL" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBlock Text="Set a future date to automatically flag this file for removal in reports." Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                        
                                        <TextBlock Text="To-Be-Removed Date" Foreground="Gray" Margin="0,0,0,5"/>
                                        <DatePicker SelectedDate="{Binding ScheduledDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,20"/>
                                        
                                        <Button Command="{Binding UpdateQueueCommand}" Height="40" Background="#333333" Foreground="White" BorderThickness="0">
                                            <StackPanel Orientation="Horizontal">
                                                <fa:ImageAwesome Icon="Calendar" Width="14" Height="14" Margin="0,0,8,0" Foreground="White"/>
                                                <TextBlock Text="Update Queue Status"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#2A1A1A" BorderBrush="#F44336" BorderThickness="1" CornerRadius="8" Padding="25">
                                    <StackPanel>
                                        <TextBlock Text="2. PERMANENT DISPOSAL" Foreground="#F44336" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBlock Text="Instantly lock this record and log it in the disposal database." Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                        
                                        <Button Command="{Binding PromptDisposalCommand}" CommandParameter="" Content="PERMANENTLY DISPOSE" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,20,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="To Be Removed Queue">
                    <Border Background="#1E1E1E" CornerRadius="0,8,8,8" Padding="15">
                        <DataGrid ItemsSource="{Binding PendingRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="White" RowBackground="#252525" AlternatingRowBackground="#1E1E1E" 
                                  HeadersVisibility="Column" GridLinesVisibility="None">
                            <DataGrid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenPendingDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                            </DataGrid.InputBindings>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Scheduled For" Binding="{Binding ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Foreground="#E57373" FontWeight="Bold"/>
                                <DataGridTextColumn Header="RR Number" Binding="{Binding RrNumber}"/>
                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="Sector" Binding="{Binding Sector}"/>
                                
                                <DataGridTemplateColumn Header="Actions">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Command="{Binding DataContext.RecoverFileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding RrNumber}" Content="Recover" Background="#4CAF50" Foreground="White" BorderThickness="0" Height="25" Margin="0,0,5,0" Padding="10,0"/>
                                                <Button Command="{Binding DataContext.PromptDisposalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding RrNumber}" Content="Dispose" Background="#F44336" Foreground="White" BorderThickness="0" Height="25" Padding="10,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </TabItem>

                <TabItem Header="Disposed Audit Log">
                    <Border Background="#1E1E1E" CornerRadius="0,8,8,8" Padding="15">
                        <DataGrid ItemsSource="{Binding DisposedHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="White" RowBackground="#252525" AlternatingRowBackground="#1E1E1E" 
                                  HeadersVisibility="Column" GridLinesVisibility="None">
                            <DataGrid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDisposedDetailsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" />
                            </DataGrid.InputBindings>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date Disposed" Binding="{Binding RemovedDate, StringFormat=yyyy-MM-dd}"/>
                                <DataGridTextColumn Header="RR Number" Binding="{Binding File.RrNumber}"/>
                                <DataGridTextColumn Header="File Name" Binding="{Binding File.FileName}" Width="*"/>
                                <DataGridTextColumn Header="Authorized By" Binding="{Binding AuthorizedBy}"/>
                                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>

        <Grid Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}}" Background="#99000000" Panel.ZIndex="100">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="450" BorderThickness="3" BorderBrush="{Binding PopupBorderColor}">
                <StackPanel>
                    <TextBlock Text="{Binding PopupFileData.RrNumber}" Foreground="{Binding PopupBorderColor}" FontSize="22" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding PopupFileData.FileName}" Foreground="White" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/> <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/> <RowDefinition Height="30"/> <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Sector:" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PopupFileData.Sector}" Foreground="White" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" Foreground="Gray"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PopupFileData.CurrentStatus}" Foreground="White" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Disposal Scheduled:" Foreground="Gray"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PopupFileData.ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Foreground="#E57373" FontWeight="Bold"/>
                    </Grid>

                    <Border Background="#2A1A1A" Padding="15" CornerRadius="5" Visibility="{Binding PopupDisposalData, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <TextBlock Text="PERMANENTLY DISPOSED" Foreground="#F44336" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding PopupDisposalData.Reason, StringFormat='Reason: {0}'}" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding PopupDisposalData.AuthorizedBy, StringFormat='Auth: {0}'}" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding CloseDialogCommand}" Content="Close Details" Height="40" Margin="0,20,0,0" Background="#333333" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsDisposalPromptOpen, Converter={StaticResource BoolToVisConverter}}" Background="#CC000000" Panel.ZIndex="110">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="450" BorderThickness="1" BorderBrush="#F44336">
                <StackPanel>
                    <TextBlock Text="AUTHORIZE DISPOSAL" Foreground="#F44336" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding PendingDisposalRrNumber, StringFormat='Target File: {0}'}" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Reason for Disposal *" Foreground="#E57373" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding DisposalReason, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#2A1A1A" Foreground="White" BorderBrush="#F44336" Padding="5,0" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Authorized By *" Foreground="#E57373" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding AuthorizedBy, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#2A1A1A" Foreground="White" BorderBrush="#F44336" Padding="5,0" Margin="0,0,0,30"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelDisposalPromptCommand}" Content="Cancel" Width="100" Height="40" Background="Transparent" Foreground="Gray" BorderThickness="0" Margin="0,0,10,0"/>
                        <Button Command="{Binding ConfirmDisposalCommand}" Content="CONFIRM &amp; DISPOSE" Width="160" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>