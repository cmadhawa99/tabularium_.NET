<UserControl x:Class="ArchivumWpf.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:converters="clr-namespace:ArchivumWpf.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <converters:SectorToColorMultiConverter x:Key="SectorToColorConverter" />
    </UserControl.Resources>

    <Grid Margin="10" IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A237E" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Database" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="FULL SYSTEM DATABASE BACKUP" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Generates a complete .sql dump of all tables. Ignores all filters below." Foreground="#A8C0FF" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <Button Command="{Binding BackupSqlCommand}" HorizontalAlignment="Right" Width="180" Height="40" Background="#283593" Foreground="White" FontWeight="Bold" BorderThickness="0" Content="Run SQL Backup"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/> <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1.5*"/> </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="1. Filter Records" Foreground="#d4af37" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Serial Num" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="RR Number" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding RrNumber, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="Sector" Foreground="Gray" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding Sector, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="Current Status" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding CurrentStatus, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="File Name" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="File Type" Foreground="Gray" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding FileType, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="Start Date" Foreground="Gray" FontSize="11"/><DatePicker SelectedDate="{Binding StartDate}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="End Date" Foreground="Gray" FontSize="11"/><DatePicker SelectedDate="{Binding EndDate}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Total Pages" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding TotalPages, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="Shelf Num" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding ShelfNumber, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="Deck Num" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding DeckNumber, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="File Num" Foreground="Gray" FontSize="11"/><TextBox Text="{Binding FileNumber, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#15202B" BorderBrush="#4FC3F7" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="SYSTEM ENTRY TIMESTAMPS (When record was saved)" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Added From:" Foreground="Gray" FontSize="11" VerticalAlignment="Center" Width="70"/>
                                    <DatePicker SelectedDate="{Binding AddedDateFrom}" Width="100" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,5,0"/>
                                    <materialDesign:TimePicker SelectedTime="{Binding AddedTimeFrom}" Width="80" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Text="Added To:" Foreground="Gray" FontSize="11" VerticalAlignment="Center" Width="60"/>
                                    <DatePicker SelectedDate="{Binding AddedDateTo}" Width="100" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333" Margin="0,0,5,0"/>
                                    <materialDesign:TimePicker SelectedTime="{Binding AddedTimeTo}" Width="80" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#2A1B1B" BorderBrush="#E57373" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="REMOVAL &amp; ARCHIVE CRITERIA" Foreground="#E57373" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Grid.Column="0" Content="Filter: Is Removed?" IsThreeState="True" IsChecked="{Binding IsRemovedFilter}" Foreground="White" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="To Be Removed Date" Foreground="Gray" FontSize="11"/>
                                    <DatePicker SelectedDate="{Binding ToBeRemovedDate}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Actual Removed Date" Foreground="Gray" FontSize="11"/>
                                    <DatePicker SelectedDate="{Binding RemovedDate}" Height="28" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#333"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <Button Command="{Binding ClearFiltersCommand}" Content="Clear All Filters &amp; Toggles" HorizontalAlignment="Left" Background="Transparent" Foreground="#E57373" BorderThickness="0" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="2. Select Columns to Export" Foreground="#d4af37" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <CheckBox IsChecked="{Binding EnableRowColors}" Content="Enable Row Sector Colors" Foreground="#4CAF50" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IncAddedDate}" Content="Added Stamp" Foreground="#4FC3F7" Margin="0,0,15,8"/>
                            
                            <CheckBox IsChecked="{Binding IncSerial}" Content="Serial Num" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncRrNumber}" Content="RR Num" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncSector}" Content="Sector" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncSubject}" Content="Subject Num" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncFileName}" Content="File Name" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncFileType}" Content="File Type" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncStartDate}" Content="Start Date" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncEndDate}" Content="End Date" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncPages}" Content="Pages" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncShelf}" Content="Shelf" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncDeck}" Content="Deck" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncFileNum}" Content="File Num" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncStatus}" Content="Status" Foreground="White" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncToBeRemovedDate}" Content="To Be Removed Date" Foreground="#E57373" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncRemovedDate}" Content="Removed Date" Foreground="#E57373" Margin="0,0,15,8"/>
                            <CheckBox IsChecked="{Binding IncIsRemoved}" Content="Is Removed" Foreground="#E57373" Margin="0,0,15,8"/>
                        </WrapPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="Transparent" Foreground="White" RowBackground="#252525" AlternatingRowBackground="#1E1E1E" 
                          HeadersVisibility="Column" GridLinesVisibility="None" 
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                          
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="8,0,0,1"/>
                            <Setter Property="BorderBrush">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource SectorToColorConverter}" ConverterParameter="Border">
                                        <Binding Path="Sector" />
                                        <Binding Path="DataContext.EnableRowColors" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        <Binding Path="DataContext.RawSectors" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                          
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding AddedDateTime, StringFormat=yyyy-MM-dd HH:mm}" Visibility="{Binding Data.IncAddedDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        
                        <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Visibility="{Binding Data.IncSerial, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="RR Num" Binding="{Binding RrNumber}" Visibility="{Binding Data.IncRrNumber, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Sector" Binding="{Binding Sector}" Visibility="{Binding Data.IncSector, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource SectorToColorConverter}" ConverterParameter="Text">
                                                <Binding Path="Sector" />
                                                <Binding Path="DataContext.EnableRowColors" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                <Binding Path="DataContext.RawSectors" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Subject Num" Binding="{Binding SubjectNumber}" Visibility="{Binding Data.IncSubject, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Visibility="{Binding Data.IncFileName, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="File Type" Binding="{Binding FileType}" Visibility="{Binding Data.IncFileType, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncStartDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncEndDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Pages" Binding="{Binding TotalPages}" Visibility="{Binding Data.IncPages, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Shelf" Binding="{Binding ShelfNumber}" Visibility="{Binding Data.IncShelf, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Deck" Binding="{Binding DeckNumber}" Visibility="{Binding Data.IncDeck, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="File Num" Binding="{Binding FileNumber}" Visibility="{Binding Data.IncFileNum, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding CurrentStatus}" Visibility="{Binding Data.IncStatus, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        
                        <DataGridTextColumn Header="To Be Removed" Binding="{Binding ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncToBeRemovedDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Removed Date" Binding="{Binding RemovedDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncRemovedDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                        <DataGridTextColumn Header="Is Removed" Binding="{Binding IsRemoved}" Visibility="{Binding Data.IncIsRemoved, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,10,0,15">
                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Gray">
                        <Run Text="Total Matches: "/>
                        <Run Text="{Binding TotalResultCount}" FontWeight="Bold" Foreground="White"/>
                    </TextBlock>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding PreviousPageCommand}" Content="&#x25C0; Prev" Width="80" Height="28" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,15,0"/>
                        <TextBlock VerticalAlignment="Center" Foreground="White">
                            <Run Text="Page "/>
                            <Run Text="{Binding CurrentPage}" FontWeight="Bold" Foreground="#d4af37"/>
                            <Run Text=" of "/>
                            <Run Text="{Binding TotalPageCount}" FontWeight="Bold"/> </TextBlock>
                        <Button Command="{Binding NextPageCommand}" Content="Next &#x25B6;" Width="80" Height="28" Background="#333333" Foreground="White" BorderThickness="0" Margin="15,0,0,0"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding ExportCsvCommand}" Content="Download CSV" Width="140" Height="40" Background="#333333" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0"/>
                    <Button Command="{Binding ExportExcelCommand}" Content="Download Excel" Width="140" Height="40" Background="#2E7D32" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>