<UserControl x:Class="ArchivumWpf.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:converters="clr-namespace:ArchivumWpf.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             xmlns:controls="clr-namespace:ArchivumWpf.Controls"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:BindingProxy x:Key="Proxy" Data="{Binding}" />

        <Style x:Key="RibbonTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RibbonComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                                            <fa:ImageAwesome Icon="ChevronDown" Width="8" Height="8" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False">
                                <Border x:Name="DropDownBorder" Background="{DynamicResource CardBackground}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" CornerRadius="2" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer Margin="0,2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Resources>
                <Style TargetType="CalendarItem">
                    <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style TargetType="CalendarDayButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A107C41"/> 
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource PrimaryAccent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource WindowBackground}"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <Style TargetType="CalendarButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A107C41"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PART_Watermark" Text="Date..." Foreground="{DynamicResource TextMuted}" Opacity="0.7" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=DatePickerTextBox}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RibbonDatePicker" TargetType="DatePicker">
            <Setter Property="CalendarStyle" Value="{StaticResource ModernCalendarStyle}"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Margin="2,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" FontSize="12"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="20" Margin="0,0,2,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <fa:ImageAwesome Icon="Calendar" Width="10" Height="10" Foreground="{DynamicResource PrimaryAccent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RibbonLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Width" Value="90"/> <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="RibbonTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="15,6" BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="Transparent" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" Padding="15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{x:Static loc:Strings.Rep_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="18" FontWeight="SemiBold" Margin="0,0,15,0"/>
                <Rectangle Width="1" Height="14" Fill="{DynamicResource BorderColor}" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Style="{StaticResource RibbonTabControl}">
            
            <TabItem Header="{x:Static loc:Strings.Rep_SectionDataFilters}">
                <Border Height="125" Background="{DynamicResource CardBackground}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            
                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblSerialNumber}" Style="{StaticResource RibbonLabel}"/>
                                            <TextBox Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="110"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblRrNumber}" Style="{StaticResource RibbonLabel}"/>
                                            <TextBox Text="{Binding RrNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="110"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblFileName}" Style="{StaticResource RibbonLabel}"/>
                                            <TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="110"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionIdentifiers}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblSector}" Style="{StaticResource RibbonLabel}" Width="120"/>
                                            <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding Sector, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonComboBox}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblFileType}" Style="{StaticResource RibbonLabel}" Width="120"/>
                                            <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding FileType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonComboBox}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblCurrentStatus}" Style="{StaticResource RibbonLabel}" Width="120"/>
                                            <TextBox Text="{Binding CurrentStatus, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="120"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionClassification}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblContentStartDate}" Style="{StaticResource RibbonLabel}" Width="160"/>
                                            <DatePicker SelectedDate="{Binding StartDate}" Style="{StaticResource RibbonDatePicker}" Width="110"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblContentEndDate}" Style="{StaticResource RibbonLabel}" Width="160"/>
                                            <DatePicker SelectedDate="{Binding EndDate}" Style="{StaticResource RibbonDatePicker}" Width="110"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionContentDates}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblShelfNumber}" Style="{StaticResource RibbonLabel}" Width="89"/>
                                            <TextBox Text="{Binding ShelfNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="70" Margin="0,0,10,0"/>
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblDeckNumber}" Style="{StaticResource RibbonLabel}" Width="89"/>
                                            <TextBox Text="{Binding DeckNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="70"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblFileNumber}" Style="{StaticResource RibbonLabel}" Width="89"/>
                                            <TextBox Text="{Binding FileNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="70" Margin="0,0,10,0"/>
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblTotalPages}" Style="{StaticResource RibbonLabel}" Width="89"/>
                                            <TextBox Text="{Binding TotalPages, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RibbonTextBox}" Width="70"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionPhysicalStorage}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                            <Border Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <Button Command="{Binding ClearFiltersCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <StackPanel>
                                                <fa:ImageAwesome Icon="Eraser" Width="20" Height="20" Foreground="{DynamicResource DangerAccent}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="{x:Static loc:Strings.Rep_BtnResetFilters}" Foreground="{DynamicResource TextMain}" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionActions}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Rep_SectionEntryAndDisposal}">
                 <Border Height="125" Background="{DynamicResource CardBackground}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            
                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblAddedAfter}" Style="{StaticResource RibbonLabel}" Width="160"/>
                                            <DatePicker SelectedDate="{Binding AddedDateFrom}" Style="{StaticResource RibbonDatePicker}" Width="110" Margin="0,0,5,0"/>
    
                                            <controls:TimeSpinnerControl SelectedTime="{Binding AddedTimeFrom, Mode=TwoWay}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblAddedBefore}" Style="{StaticResource RibbonLabel}" Width="160"/>
                                            <DatePicker SelectedDate="{Binding AddedDateTo}" Style="{StaticResource RibbonDatePicker}" Width="110" Margin="0,0,5,0"/>
    
                                            <controls:TimeSpinnerControl SelectedTime="{Binding AddedTimeTo, Mode=TwoWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionEntryTimestamps}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="10,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <CheckBox Content="{x:Static loc:Strings.Rep_ChkIsRemoved}" IsThreeState="True" IsChecked="{Binding IsRemovedFilter}" Foreground="{DynamicResource DangerAccent}" FontSize="12" Margin="5,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblScheduledRemoval}" Style="{StaticResource RibbonLabel}" Width="160"/>
                                            <DatePicker SelectedDate="{Binding ToBeRemovedDate}" Style="{StaticResource RibbonDatePicker}" Width="110"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{x:Static loc:Strings.Rep_LblActualRemovalDate}" Style="{StaticResource RibbonLabel}" Width="160"/>
                                            <DatePicker SelectedDate="{Binding RemovedDate}" Style="{StaticResource RibbonDatePicker}" Width="110"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionRemovalCriteria}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Rep_SectionOutputColumns}">
                 <Border Height="125" Background="{DynamicResource CardBackground}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Padding="15,5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <WrapPanel Grid.Row="0" Orientation="Vertical" Height="80">
                                        <WrapPanel.Resources>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                                <Setter Property="Margin" Value="0,0,15,4"/>
                                                <Setter Property="Width" Value="110"/>
                                                <Setter Property="FontSize" Value="11"/>
                                            </Style>
                                        </WrapPanel.Resources>
                                        <CheckBox IsChecked="{Binding IncAddedDate}" Content="{x:Static loc:Strings.Rep_ChkColAddedStamp}"/>
                                        <CheckBox IsChecked="{Binding IncSerial}" Content="{x:Static loc:Strings.Rep_ChkColSerialNum}"/>
                                        <CheckBox IsChecked="{Binding IncRrNumber}" Content="{x:Static loc:Strings.Rep_ChkColRrNum}"/>
                                        <CheckBox IsChecked="{Binding IncSector}" Content="{x:Static loc:Strings.Rep_ChkColSector}"/>
                                        <CheckBox IsChecked="{Binding IncSubject}" Content="{x:Static loc:Strings.Rep_ChkColSubjectNum}"/>
                                        <CheckBox IsChecked="{Binding IncFileName}" Content="{x:Static loc:Strings.Rep_ChkColFileName}"/>
                                        <CheckBox IsChecked="{Binding IncFileType}" Content="{x:Static loc:Strings.Rep_ChkColFileType}"/>
                                        <CheckBox IsChecked="{Binding IncStartDate}" Content="{x:Static loc:Strings.Rep_ChkColStartDate}"/>
                                        <CheckBox IsChecked="{Binding IncEndDate}" Content="{x:Static loc:Strings.Rep_ChkColEndDate}"/>
                                        <CheckBox IsChecked="{Binding IncPages}" Content="{x:Static loc:Strings.Rep_ChkColPages}"/>
                                        <CheckBox IsChecked="{Binding IncShelf}" Content="{x:Static loc:Strings.Rep_ChkColShelf}"/>
                                        <CheckBox IsChecked="{Binding IncDeck}" Content="{x:Static loc:Strings.Rep_ChkColDeck}"/>
                                        <CheckBox IsChecked="{Binding IncFileNum}" Content="{x:Static loc:Strings.Rep_ChkColFileNum}"/>
                                        <CheckBox IsChecked="{Binding IncStatus}" Content="{x:Static loc:Strings.Rep_ChkColStatus}"/>
                                        <CheckBox IsChecked="{Binding IncToBeRemovedDate}" Content="{x:Static loc:Strings.Rep_ChkColScheduledDate}" Foreground="{DynamicResource DangerAccent}"/>
                                        <CheckBox IsChecked="{Binding IncRemovedDate}" Content="{x:Static loc:Strings.Rep_ChkColRemovedDate}" Foreground="{DynamicResource DangerAccent}"/>
                                        <CheckBox IsChecked="{Binding IncIsRemoved}" Content="{x:Static loc:Strings.Rep_ChkColIsRemoved}" Foreground="{DynamicResource DangerAccent}"/>
                                    </WrapPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionVisibleColumns}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                 </Border>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Rep_SectionExportTools}">
                 <Border Height="125" Background="{DynamicResource CardBackground}">
                     <StackPanel Orientation="Horizontal">
                        
                        <Border Padding="25,5" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Command="{Binding ExportCsvCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,25,0">
                                        <StackPanel>
                                            <fa:ImageAwesome Icon="FileTextOutline" Width="28" Height="28" Foreground="{DynamicResource PrimaryAccent}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                            <TextBlock Text="{x:Static loc:Strings.Rep_BtnExportCsv}" Foreground="{DynamicResource TextMain}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Command="{Binding ExportExcelCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <StackPanel>
                                            <fa:ImageAwesome Icon="FileExcelOutline" Width="28" Height="28" Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                            <TextBlock Text="{x:Static loc:Strings.Rep_BtnExportExcel}" Foreground="{DynamicResource TextMain}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_SectionDataExport}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>

                        <Border Padding="25,5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                    <Button Command="{Binding BackupSqlCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <StackPanel>
                                            <fa:ImageAwesome Icon="Database" Width="28" Height="28" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                            <TextBlock Text="{x:Static loc:Strings.Rep_BtnExportSql}" Foreground="{DynamicResource TextMain}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Rep_BackupTitle}" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>
                        
                     </StackPanel>
                 </Border>
            </TabItem>

        </TabControl>

        <DataGrid Grid.Row="2" ItemsSource="{Binding PreviewRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  CanUserResizeColumns="True" CanUserResizeRows="True"
                  Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" RowBackground="{DynamicResource WindowBackground}" AlternatingRowBackground="{DynamicResource CardBackground}" 
                  HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="{DynamicResource BorderColor}" VerticalGridLinesBrush="{DynamicResource BorderColor}" 
                  BorderThickness="0" Margin="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Padding" Value="0,4"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0A107C41"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1A107C41"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
              
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="BorderThickness" Value="0,2,1,2"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColTimestamp}" Binding="{Binding AddedDateTime, StringFormat=yyyy-MM-dd HH:mm}" Visibility="{Binding Data.IncAddedDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="140"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColSerial}" Binding="{Binding SerialNumber}" Visibility="{Binding Data.IncSerial, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="100"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColRrNum}" Binding="{Binding RrNumber}" Visibility="{Binding Data.IncRrNumber, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" FontFamily="Consolas" Width="140"/>
                
                <DataGridTemplateColumn Header="{x:Static loc:Strings.Rep_GridColSector}" Visibility="{Binding Data.IncSector, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Ellipse Width="8" Height="8" Fill="{Binding SectorColorHex, TargetNullValue='#8f9bb3'}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Sector}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColSubjectNum}" Binding="{Binding SubjectNumber}" Visibility="{Binding Data.IncSubject, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="120"/>
                
                <DataGridTemplateColumn Header="{x:Static loc:Strings.Rep_GridColFileName}" Visibility="{Binding Data.IncFileName, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="250">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColFileType}" Binding="{Binding FileType}" Visibility="{Binding Data.IncFileType, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="120"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColStartDate}" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncStartDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="120"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColEndDate}" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncEndDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="120"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColPages}" Binding="{Binding TotalPages}" Visibility="{Binding Data.IncPages, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="80"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColShelf}" Binding="{Binding ShelfNumber}" Visibility="{Binding Data.IncShelf, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="80"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColDeck}" Binding="{Binding DeckNumber}" Visibility="{Binding Data.IncDeck, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="80"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColFileNum}" Binding="{Binding FileNumber}" Visibility="{Binding Data.IncFileNum, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="80"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColStatus}" Binding="{Binding CurrentStatus}" Visibility="{Binding Data.IncStatus, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Width="120"/>
                
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColScheduledRemoval}" Binding="{Binding ToBeRemovedDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncToBeRemovedDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Foreground="{DynamicResource DangerAccent}" Width="140"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColRemovedDate}" Binding="{Binding RemovedDate, StringFormat=yyyy-MM-dd}" Visibility="{Binding Data.IncRemovedDate, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Foreground="{DynamicResource DangerAccent}" Width="140"/>
                <DataGridTextColumn Header="{x:Static loc:Strings.Rep_GridColIsRemoved}" Binding="{Binding IsRemoved}" Visibility="{Binding Data.IncIsRemoved, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisConverter}}" Foreground="{DynamicResource DangerAccent}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="{DynamicResource PrimaryAccent}" Padding="15,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource WindowBackground}" FontSize="12" Opacity="0.9">
                        <Run Text="{x:Static loc:Strings.Rep_TotalQueriesMatched}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding TotalResultCount}" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding PreviousPageCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8,4" Margin="0,0,5,0">
                        <fa:ImageAwesome Icon="ChevronLeft" Width="10" Height="10" Foreground="{DynamicResource WindowBackground}"/>
                    </Button>
                    <TextBlock Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="5,0">
                        <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalPageCount, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8,4" Margin="5,0,0,0">
                        <fa:ImageAwesome Icon="ChevronRight" Width="10" Height="10" Foreground="{DynamicResource WindowBackground}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>