<UserControl x:Class="ArchivumWpf.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:converters="clr-namespace:ArchivumWpf.Converters"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="DATA EXPORT &amp; REPORTS" Foreground="#d4af37" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="#1E1E1E" CornerRadius="10" Padding="20">
                <Grid IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"> <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Serial Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SerialNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="RR Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding RrNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Sector" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Sector}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>

                        <TextBlock Text="Subject Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SubjectNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="File Name" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FileName}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="File Type" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FileType}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>

                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Total Pages" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding TotalPages}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Shelf Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ShelfNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>

                        <TextBlock Text="Deck Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding DeckNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="File Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FileNumber}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="20" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding ClearFiltersCommand}" Content="Clear Filters" Width="100" Height="45" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,20,0"/>
                
                <Button Command="{Binding ExportCsvCommand}" Width="150" Height="45" Background="#d4af37" Foreground="Black" FontWeight="Bold" BorderThickness="0" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="FileTextOutline" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Export CSV"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExportExcelCommand}" Width="150" Height="45" Background="#2E7D32" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="FileExcelOutline" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Export Excel"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding BackupSqlCommand}" Width="180" Height="45" Background="#1565C0" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Database" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Full SQL Backup"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>