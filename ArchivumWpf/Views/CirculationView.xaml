<UserControl x:Class="ArchivumWpf.Views.CirculationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:loc="clr-namespace:ArchivumWpf.Localization"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Background" Value="#0A000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,10,20,20" MaxWidth="1600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{x:Static loc:Strings.Circ_MainTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="32" FontFamily="Georgia" FontWeight="Black" Margin="0,0,0,5"/>
            <TextBlock Text="{x:Static loc:Strings.Circ_MainDesc}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,0,0,10"/>
            
            <Grid Margin="0,10,0,15">
                <Rectangle Height="1" Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>
                <Rectangle Width="8" Height="8" Fill="{DynamicResource BorderColor}" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center">
                    <Rectangle.RenderTransform>
                        <RotateTransform Angle="45"/>
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>
            
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="25,12" Margin="0,0,15,15" CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Background="{DynamicResource CardBackground}" Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#0A000000"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{x:Static loc:Strings.Circ_TabDesk}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,30,0,20">
                        
                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="32" Padding="8" Margin="0,0,0,40" Width="800" HorizontalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <fa:ImageAwesome Grid.Column="0" Icon="Crosshairs" Width="22" Height="22" Foreground="{DynamicResource PrimaryAccent}" Margin="25,0,20,0"/>
                                
                                <TextBox Grid.Column="1" Text="{Binding TargetRrNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                         FontSize="18" FontFamily="Georgia" VerticalContentAlignment="Center" Margin="0,0,10,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="{x:Static loc:Strings.Circ_SearchWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.5" FontSize="16" FontFamily="Georgia"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" Command="{Binding CheckFileCommand}" 
                                        Background="{DynamicResource BorderColor}" Foreground="{DynamicResource TextMain}" 
                                        FontWeight="Bold" BorderThickness="0" Padding="35,16" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="24">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                    <fa:ImageAwesome Icon="Search" Width="14" Height="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{x:Static loc:Strings.Circ_BtnAssess}" FontSize="14"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            
                            <fa:ImageAwesome Icon="Book" Width="120" Height="120" Foreground="{DynamicResource TextMuted}" Opacity="0.1" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                            <TextBlock Text="{x:Static loc:Strings.Circ_AwaitingScanTitle}" Foreground="{DynamicResource TextMuted}" Opacity="0.5" FontSize="18" FontWeight="Bold" FontFamily="Georgia" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="{x:Static loc:Strings.Circ_AwaitingScanDesc}" Foreground="{DynamicResource TextMuted}" Opacity="0.4" FontSize="14" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Grid Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}" MaxWidth="1100" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="40"/> <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="3" ClipToBounds="True">
                                <Border BorderBrush="{Binding LoadedFileColor}" BorderThickness="1" CornerRadius="13" Padding="35" ClipToBounds="True">
                                    <Grid>
                                        <Grid Width="120" Height="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0" Opacity="0.2" IsHitTestVisible="False">
                                            <Grid.RenderTransform>
                                                <RotateTransform Angle="15" CenterX="60" CenterY="60"/>
                                            </Grid.RenderTransform>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="-2,0,2,0"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="2,0,-2,0"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="0,-2,0,2"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="0,2,0,-2"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="-2,-2,2,2"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="2,2,-2,-2"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="-2,2,2,-2"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="2,-2,-2,2"/>
                                            <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{Binding LoadedFileColor}"/>
                                        </Grid>

                                        <StackPanel>
                                            <TextBlock Text="{x:Static loc:Strings.Circ_DossierIntel}" Foreground="{Binding LoadedFileColor}" FontSize="13" FontWeight="Bold" Margin="0,0,0,20"/>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="35"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="35"/>
                                                    <RowDefinition Height="35"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblRrNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedFile.RrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" FontSize="16"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSubjectName}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,8,0,0" FontSize="12"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LoadedFile.FileName}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,15" FontSize="15"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LoadedFile.Sector}" Foreground="{Binding LoadedFileColor}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblCurrentStatus}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LoadedFile.CurrentStatus}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>

                            <Grid Grid.Column="2">
                                
                                <Border Visibility="{Binding CanIssue, Converter={StaticResource BoolToVisConverter}}" Background="#0A000000" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1" CornerRadius="16" Padding="35" ClipToBounds="True">
                                    <Grid>
                                        <fa:ImageAwesome Icon="SignOut" Width="120" Height="120" Foreground="{DynamicResource PrimaryAccent}" Opacity="0.05" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-25,-25,0" IsHitTestVisible="False"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Static loc:Strings.Circ_IssueTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                                            
                                            <TextBox Text="{Binding BorrowerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Margin="0,0,0,20"/>
                                            
                                            <TextBlock Text="{x:Static loc:Strings.Circ_BorrowerWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.5" IsHitTestVisible="False" Margin="15,-45,0,30" FontSize="14" FontFamily="Georgia">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BorrowerName}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding BorrowerName}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Button Command="{Binding ExecuteIssueCommand}" Height="50" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Padding="30,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <fa:ImageAwesome Icon="SignOut" Width="16" Height="16" Margin="0,0,12,0" Foreground="{DynamicResource WindowBackground}"/>
                                                                <TextBlock Text="{x:Static loc:Strings.Circ_BtnAuthorizeIssue}" FontSize="13"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Visibility="{Binding CanReturn, Converter={StaticResource BoolToVisConverter}}" Background="#0A000000" BorderBrush="{DynamicResource PrimaryAccent}" BorderThickness="1" CornerRadius="16" Padding="35" ClipToBounds="True">
                                    <Grid>
                                        <fa:ImageAwesome Icon="SignIn" Width="120" Height="120" Foreground="{DynamicResource PrimaryAccent}" Opacity="0.05" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-25,-25,0" IsHitTestVisible="False"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Static loc:Strings.Circ_ReturnTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                                            <TextBlock Text="{x:Static loc:Strings.Circ_ReturnDesc}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,0,0,35" TextWrapping="Wrap"/>
                                            
                                            <Button Command="{Binding ExecuteReturnCommand}" Height="50" Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Padding="30,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <fa:ImageAwesome Icon="SignIn" Width="16" Height="16" Margin="0,0,12,0" Foreground="{DynamicResource WindowBackground}"/>
                                                                <TextBlock Text="{x:Static loc:Strings.Circ_BtnProcessReturn}" FontSize="13"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Circ_TabActiveLoans}">
                <StackPanel HorizontalAlignment="Stretch">
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="3">
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="13">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="25,20">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:ImageAwesome Icon="Book" Width="16" Height="16" Foreground="#E5C365" Margin="0,0,12,0"/>
                                        <TextBlock Text="{x:Static loc:Strings.Circ_ActiveLoansHeader}" Foreground="#E5C365" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveLoans}" 
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" Foreground="{DynamicResource TextMain}" 
                                          RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                                          HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" Margin="10,0" MinHeight="400">
                                    
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="Padding" Value="20,15"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Padding" Value="0,15"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#05000000"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static loc:Strings.Circ_ColRrNumber}" Binding="{Binding SnapshotRrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontFamily="Consolas"/>
                                        
                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColFileName}" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SnapshotFileName}" ToolTip="{Binding SnapshotFileName}" Foreground="{DynamicResource TextMain}" FontFamily="Georgia" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColSector}" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="10" Height="10" Fill="{Binding SnapshotSectorColor, TargetNullValue='#8f9bb3'}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding SnapshotSector}" ToolTip="{Binding SnapshotSector}" Foreground="{DynamicResource TextMain}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColBorrower}" Width="250">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BorrowerName}" ToolTip="{Binding BorrowerName}" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        
                                        <DataGridTextColumn Header="{x:Static loc:Strings.Circ_ColIssueDate}" Binding="{Binding BorrowedDate, StringFormat=MMM dd yyyy}" Foreground="{DynamicResource TextMuted}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.Circ_TabLedger}">
                <StackPanel HorizontalAlignment="Stretch">
                    
                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="20" Padding="6" Margin="0,0,0,20" MaxWidth="600" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:ImageAwesome Grid.Column="0" Icon="Search" Width="14" Height="14" Foreground="{DynamicResource PrimaryAccent}" Margin="15,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding HistorySearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" 
                                     FontSize="14" FontFamily="Georgia" VerticalContentAlignment="Center" Margin="0,0,10,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="{x:Static loc:Strings.Circ_LedgerSearchWatermark}" Foreground="{DynamicResource TextMuted}" Opacity="0.5" FontSize="14" FontFamily="Georgia"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="3">
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="13">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <DataGrid Grid.Row="0" ItemsSource="{Binding BorrowHistoryRecords}" 
                                          SelectedItem="{Binding SelectedHistoryRecord, Mode=TwoWay}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" Foreground="{DynamicResource TextMain}" 
                                          RowBackground="Transparent" AlternatingRowBackground="Transparent" 
                                          HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" Margin="10,0" MinHeight="400">
                                    
                                    <DataGrid.InputBindings>
                                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding ShowHistoryDetailsCommand}" />
                                    </DataGrid.InputBindings>

                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="Padding" Value="20,15"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Padding" Value="0,15"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#05000000"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static loc:Strings.Circ_ColRrNumber}" Binding="{Binding SnapshotRrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontFamily="Consolas" Width="140"/>
                                        
                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColFileName}" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SnapshotFileName}" ToolTip="{Binding SnapshotFileName}" Foreground="{DynamicResource TextMain}" FontFamily="Georgia" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColSector}" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="10" Height="10" Fill="{Binding SnapshotSectorColor, TargetNullValue='#8f9bb3'}" Stroke="{DynamicResource TextMain}" StrokeThickness="1" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding SnapshotSector}" ToolTip="{Binding SnapshotSector}" Foreground="{DynamicResource TextMain}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColBorrower}" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BorrowerName}" ToolTip="{Binding BorrowerName}" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        
                                        <DataGridTextColumn Header="{x:Static loc:Strings.Circ_ColIssueDate}" Binding="{Binding BorrowedDate, StringFormat=MMM dd yyyy}" Foreground="{DynamicResource TextMuted}" Width="110"/>

                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Circ_ColStatus}" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border BorderThickness="1" CornerRadius="12" Padding="12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                                                <Setter Property="Background" Value="Transparent"/> 
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReturned}" Value="False">
                                                                        <Setter Property="BorderBrush" Value="#E5C365"/>
                                                                        <Setter Property="Background" Value="#1AE5C365"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="9" FontWeight="Bold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Circ_StatusReturned}"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsReturned}" Value="False">
                                                                            <Setter Property="Text" Value="{x:Static loc:Strings.Circ_StatusActiveLoan}"/>
                                                                            <Setter Property="Foreground" Value="#E5C365"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        
                                        <DataGridTextColumn Header="{x:Static loc:Strings.Circ_ColReturnDate}" Binding="{Binding ReturnedDate, StringFormat=MMM dd\\ yyyy, TargetNullValue={x:Static loc:Strings.Circ_PendingReturn}}" Foreground="{DynamicResource TextMuted}" Width="130"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="30,20" Background="{DynamicResource CardBackground}" CornerRadius="0,0,13,13">
                                    <Grid>
                                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12">
                                            <Run Text="{x:Static loc:Strings.Circ_TotalHistoryRecords}"/>
                                            <Run Text="{Binding HistoryTotalCount, Mode=OneWay}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource PaginationButtonStyle}" Padding="12,8" Margin="0,0,10,0">
                                                <fa:ImageAwesome Icon="ChevronLeft" Width="10" Height="10" Foreground="{DynamicResource TextMuted}"/>
                                            </Button>
                                            
                                            <Border Background="{DynamicResource PrimaryAccent}" CornerRadius="8" Padding="16,8" Margin="0,0,10,0">
                                                <TextBlock Foreground="{DynamicResource WindowBackground}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center">
                                                    <Run Text="{Binding HistoryCurrentPage, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                            
                                            <Button Command="{Binding NextPageCommand}" Style="{StaticResource PaginationButtonStyle}" Padding="12,8">
                                                <fa:ImageAwesome Icon="ChevronRight" Width="10" Height="10" Foreground="{DynamicResource TextMuted}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Border>
                </StackPanel>
            </TabItem>

        </TabControl>

        <Grid Grid.Row="0" Grid.RowSpan="2" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="#CC000000" CornerRadius="16"/>
            
            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" BorderBrush="{Binding PopupBorderColor, FallbackValue='#f2ca50'}" BorderThickness="2" ClipToBounds="True">
                <Grid>
                    
                    <Grid Width="180" Height="180" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-30,-30,0" Opacity="0.15" IsHitTestVisible="False">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="15" CenterX="90" CenterY="90"/>
                        </Grid.RenderTransform>
                        
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="-2,0,2,0"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="2,0,-2,0"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="0,-2,0,2"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="0,2,0,-2"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="-2,-2,2,2"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="2,2,-2,-2"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="-2,2,2,-2"/>
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{DynamicResource TextMain}" Margin="2,-2,-2,2"/>
                        
                        <fa:ImageAwesome Icon="AddressCardOutline" Foreground="{Binding PopupBorderColor, FallbackValue='#f2ca50'}"/>
                    </Grid>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <fa:ImageAwesome Icon="FileText" Width="24" Height="24" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding DialogTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="20" FontFamily="Georgia" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="Auto"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/> <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblTransactionId}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedHistoryRecord.Id}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblBorrowerName}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedHistoryRecord.BorrowerName}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblIssueDate}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedHistoryRecord.BorrowedDate, StringFormat=dd MMM yyyy}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblReturnDate}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedHistoryRecord.ReturnedDate, StringFormat=dd MMM yyyy, TargetNullValue={x:Static loc:Strings.Circ_PendingReturn}}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Rectangle Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblRrNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedHistoryRecord.SnapshotRrNumber}" Foreground="{DynamicResource PrimaryAccent}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSector}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedHistoryRecord.SnapshotSector}" Foreground="{Binding PopupBorderColor}" FontWeight="Bold" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSubjectFileName}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedHistoryRecord.SnapshotFileName}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,15"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblSubjectNumber}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedHistoryRecord.SnapshotSubjectNumber, TargetNullValue={x:Static loc:Strings.Circ_None}}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblFileType}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedHistoryRecord.SnapshotFileType, TargetNullValue={x:Static loc:Strings.Circ_None}}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblChronoSpan}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedHistoryRecord.SnapshotStartDate, StringFormat=dd MMM yyyy, TargetNullValue={x:Static loc:Strings.Circ_NA}}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                                <TextBlock Text="{x:Static loc:Strings.Circ_LblTo}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding SelectedHistoryRecord.SnapshotEndDate, StringFormat=dd MMM yyyy, TargetNullValue={x:Static loc:Strings.Circ_NA}}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="{x:Static loc:Strings.Circ_LblPhysicalLocation}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{x:Static loc:Strings.Circ_LblPages}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding SelectedHistoryRecord.SnapshotTotalPages, TargetNullValue='?'}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" Margin="0,0,15,0"/>
                                <TextBlock Text="{x:Static loc:Strings.Circ_LblShelf}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding SelectedHistoryRecord.SnapshotShelfNumber, TargetNullValue='?'}" Foreground="{DynamicResource TextMain}" FontWeight="Bold" Margin="0,0,15,0"/>
                                <TextBlock Text="{x:Static loc:Strings.Circ_LblDeck}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding SelectedHistoryRecord.SnapshotDeckNumber, TargetNullValue='?'}" Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>

                        <Button Command="{Binding CloseDialogCommand}" Content="{x:Static loc:Strings.Circ_BtnCloseRecord}" 
                                Height="45" Margin="0,30,0,0" Background="{DynamicResource BorderColor}" 
                                Foreground="{DynamicResource TextMain}" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
    </Grid>
</UserControl>