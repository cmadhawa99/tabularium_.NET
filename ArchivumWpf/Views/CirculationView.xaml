<UserControl x:Class="ArchivumWpf.Views.CirculationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="ISSUE FILE" Foreground="#d4af37" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="RR Number:" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding IssueRrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    
                    <TextBlock Text="Borrower Name:" Foreground="Gray" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding IssueBorrowerName, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>

                    <Button Command="{Binding IssueFileCommand}" Height="40" Margin="0,20,0,0" Background="#d4af37" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="PaperPlane" Width="14" Height="14" Margin="0,0,8,0" Foreground="Black"/>
                            <TextBlock Text="Issue File to Borrower"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="RETURN FILE" Foreground="#d4af37" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="RR Number:" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ReturnRrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>

                    <Button Command="{Binding ReturnFileCommand}" Height="40" Margin="0,20,0,0" Background="#333333" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Download" Width="14" Height="14" Margin="0,0,8,0" Foreground="White"/>
                            <TextBlock Text="Return File to Vault"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" 
                   FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,10"/>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="ACTIVE LOANS" Foreground="Gray" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveLoans}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" Background="Transparent" 
                          Foreground="White" RowBackground="#252525" AlternatingRowBackground="#1E1E1E" 
                          HeadersVisibility="Column" GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RR Number" Binding="{Binding FileRrNumber}" Width="150"/>
                        <DataGridTextColumn Header="Borrower Name" Binding="{Binding BorrowerName}" Width="*"/>
                        <DataGridTextColumn Header="File Name" Binding="{Binding File.FileName}" Width="*"/>
                        <DataGridTextColumn Header="Date Borrowed" Binding="{Binding BorrowedDate, StringFormat=dd MMM yyyy}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>