<UserControl x:Class="ArchivumWpf.Views.AddFileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
        <Border Background="#1E1E1E" CornerRadius="10" Padding="30" MaxWidth="900">
            <StackPanel>
                
                <TextBlock Text="ADD NEW FILE ENTRY" Foreground="#d4af37" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/> <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="RR Number *" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding RrNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Sector *" Foreground="Gray" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableSectors}" SelectedItem="{Binding Sector, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                        <TextBlock Text="File Name *" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Subject Number" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SubjectNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="File Type" Foreground="Gray" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding FileType, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Total Pages" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding TotalPages, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Text="PHYSICAL LOCATION" Foreground="#8f9bb3" FontWeight="Bold" Margin="0,15,0,10"/>

                    <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,0,15">
                            <TextBlock Text="Shelf Number" Foreground="Gray" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ShelfNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Margin="0,0,0,15">
                            <TextBlock Text="Deck Number" Foreground="Gray" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding DeckNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,0,15">
                            <TextBlock Text="File Number" Foreground="Gray" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FileNumber, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="#252525" Foreground="White" BorderBrush="#333333" Padding="5,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Command="{Binding ClearFormCommand}" Content="Clear Form" Width="120" Height="40" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,15,0"/>
                    <Button Command="{Binding SaveFileCommand}" Width="150" Height="40" Background="#d4af37" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Save" Width="14" Height="14" Margin="0,0,8,0" Foreground="Black"/>
                            <TextBlock Text="Save to Vault"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>