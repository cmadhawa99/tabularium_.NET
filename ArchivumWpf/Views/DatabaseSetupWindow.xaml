<Window x:Class="ArchivumWpf.Views.DatabaseSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:converters="clr-namespace:ArchivumWpf.Converters"
        Title="Database Configuration" Height="420" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <fa:ImageAwesome Icon="Database" Width="20" Height="20" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,10,0"/>
                <TextBlock Text="Missing Configuration" Foreground="{DynamicResource PrimaryAccent}" FontSize="20" FontWeight="Bold"/>
            </StackPanel>
            
            <TextBlock Text="Your database configuration file is missing. Your security vault is intact, so you only need to provide your database connection details." TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>
            
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" FontWeight="SemiBold" Margin="0,0,0,15" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="20">
                <StackPanel>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="10"/> <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Host" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbHost}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Database Name" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbName}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="10"/> <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Username" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DbUser}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Password" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="DbPasswordBox" PasswordChanged="DbPasswordBox_PasswordChanged" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextMain}" Padding="6" BorderBrush="{DynamicResource BorderColor}"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Connect and Save" Command="{Binding ConnectAndSaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource PrimaryAccent}" Foreground="White" Padding="15,10" Cursor="Hand" IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>