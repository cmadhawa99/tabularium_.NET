<Window x:Class="ArchivumWpf.MainWindow"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:views="clr-namespace:ArchivumWpf.Views"
        xmlns:viewmodels="clr-namespace:ArchivumWpf.ViewModels"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archive — Weligepola DC Vault" 
        Height="900" Width="1380" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:SearchViewModel}">
            <views:SearchView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:CirculationViewModel}">
            <views:CirculationView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:EntryViewModel}">
            <views:EntryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:DisposalViewModel}">
            <views:DisposalView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/> <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E">
            <StackPanel Margin="0,20,0,0">
                
                <TextBlock Text="ARCHIVUM" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Weligepola Divisional Council" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Command="{Binding NavigateToDashboardCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="PieChart" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToSearchCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="Search" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Search Vault" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToCirculationCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="Exchange" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Circulation" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToAddFileCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="Plus" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Entry" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateToDisposalCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="Trash" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Disposal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToReportsCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="Print" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Reports" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToSettingsCommand}" Height="40" Margin="10,5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <fa:ImageAwesome Icon="Cog" Width="16" Height="16" Foreground="#8f9bb3" Margin="0,0,15,0"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#121212">
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/> <RowDefinition Height="*"/>  
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1">
                <TextBlock Text="Top Bar (User Info &amp; Theme Toggle Here)" 
                           Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}" Margin="30"/>
            
            <Border Grid.Row="1" Background="#F44336" CornerRadius="8" Padding="15,10" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,30,0"
                    Visibility="{Binding HasDisposalAlert, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisposalAlertText}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Command="{Binding GoToDisposalQueueCommand}" Content="Review" Background="#B71C1C" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>