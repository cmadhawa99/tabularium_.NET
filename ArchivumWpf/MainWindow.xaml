<Window x:Class="ArchivumWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archivum — Weligepola DC Vault" 
        Height="900" Width="1380" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E">
            <StackPanel Margin="0,20,0,0">
                
                <TextBlock Text="ARCHIVUM" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Weligepola Divisional Council" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Content="Dashboard" Command="{Binding NavigateToDashboardCommand}" 
                        Height="40" Margin="10,5" Background="#333333" Foreground="White"/>
                
                <Button Content="Search Vault" Command="{Binding NavigateToSearchCommand}" 
                        Height="40" Margin="10,5" Background="#333333" Foreground="White"/>
                
                <Button Content="Circulation" Command="{Binding NavigateToCirculationCommand}" 
                        Height="40" Margin="10,5" Background="#333333" Foreground="White"/>
                
                <Button Content="New Entry" Command="{Binding NavigateToAddFileCommand}" 
                        Height="40" Margin="10,5" Background="#333333" Foreground="White"/>
                
                <Button Content="Reports" Command="{Binding NavigateToReportsCommand}" 
                        Height="40" Margin="10,5" Background="#333333" Foreground="White"/>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#121212">
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1">
                <TextBlock Text="Top Bar (User Info &amp; Theme Toggle Here)" 
                           Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}" Margin="30"/>
            
        </Grid>
    </Grid>
</Window>