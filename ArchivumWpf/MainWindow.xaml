<Window x:Class="ArchivumWpf.MainWindow"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:views="clr-namespace:ArchivumWpf.Views"
        xmlns:viewmodels="clr-namespace:ArchivumWpf.ViewModels"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ArchivumWpf.Localization"
        Title="{x:Static loc:Strings.Main_WindowTitle}" 
        Height="900" Width="1380" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SearchViewModel}"><views:SearchView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CirculationViewModel}"><views:CirculationView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:EntryViewModel}"><views:EntryView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:DisposalViewModel}"><views:DisposalView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}"><views:ReportsView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}"><views:SettingsView /></DataTemplate>

        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="21,0,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                    <Setter Property="Background" Value="#0A000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0" Panel.ZIndex="10">
            <StackPanel Margin="0,40,0,0">
                
                <TextBlock Text="{x:Static loc:Strings.Main_BrandTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Left" Margin="25,0,25,2" TextWrapping="Wrap"/>
                <TextBlock Text="{x:Static loc:Strings.Main_BrandSubtitle}" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="25,0,25,40" TextWrapping="Wrap"/>

                <Button Command="{Binding NavigateToDashboardCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Dashboard">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="PieChart" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavDashboard}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToSearchCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Search">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Search" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavSearch}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToCirculationCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Circulation">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Exchange" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavCirculation}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding NavigateToAddFileCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Entry">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Plus" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavNewEntry}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateToDisposalCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                             <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Disposal">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                         <fa:ImageAwesome Icon="Trash" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavDisposal}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                 
                <Button Command="{Binding NavigateToReportsCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                             <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Reports">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                             </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                         <fa:ImageAwesome Icon="Print" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavReports}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                 
                <Button Command="{Binding NavigateToSettingsCommand}" Margin="0,20,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePage}" Value="Settings">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                    <Setter Property="Background" Value="#0A000000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Cog" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,15,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_NavSettings}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/> 
                <RowDefinition Height="*"/>  
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Background="{DynamicResource CardBackground}" Padding="40,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.Main_HeaderTitle}" Foreground="{DynamicResource PrimaryAccent}" FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_HeaderSubtitle}" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="2" Padding="12,6" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="UserCircle" Width="14" Height="14" Foreground="{DynamicResource PrimaryAccent}" Margin="0,0,8,0"/>
                                <TextBlock Text="{x:Static loc:Strings.Main_WelcomeUser}" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding ToggleThemeCommand}" Background="Transparent" BorderThickness="0" Margin="10,0" Cursor="Hand" ToolTip="{x:Static loc:Strings.Main_TooltipTheme}">
                            <fa:ImageAwesome Icon="MoonOutline" Width="18" Height="18" Foreground="{DynamicResource PrimaryAccent}"/>
                        </Button>
                        
                        <Button Background="Transparent" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand">
                            <fa:ImageAwesome Icon="BellOutline" Width="18" Height="18" Foreground="{DynamicResource PrimaryAccent}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}" Margin="40"/>
            
            <Border Grid.Row="1" Background="{DynamicResource DangerAccent}" CornerRadius="2" Padding="15,10" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,40,0"
                    Visibility="{Binding HasDisposalAlert, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisposalAlertText}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Command="{Binding GoToDisposalQueueCommand}" Content="{x:Static loc:Strings.Main_BtnReviewDisposal}" Background="#B71C1C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Padding="15,6" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>